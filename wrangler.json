{
	"name": "astro-portfolio",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"r2_buckets": [
		{
			"binding": "MEDIA_BUCKET",
			"bucket_name": "portfolio",
			"preview_bucket_name": "portfolio"
		}
	],
	"vars": {
		"CONTACT_TO_EMAIL": "contact@tajs.io",
		"CONTACT_FROM_EMAIL": "Portfolio Contact <noreply@tajs.io>",
		"CONTACT_SUBJECT_PREFIX": "[tajs.io] Contact Form",
		"TURNSTILE_SITE_KEY": "0x4AAAAAACj5smKRjyW5M3sV",
		"MATOMO_URL": "https://stats.tajs.io",
		"MATOMO_SITE_ID": "1"
	}
}
