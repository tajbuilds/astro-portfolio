---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ButtonLink from '../components/ButtonLink.astro';
import PillTag from '../components/PillTag.astro';
import ProjectCard from '../components/ProjectCard.astro';

const featured = (await getCollection('work'))
	.filter((entry) => !entry.data.draft && entry.data.featured)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 4);

const techGroups = {
	'Edge / Cloud': ['Cloudflare Workers', 'Routing & Rules', 'Access Control', 'Observability'],
	Automation: ['Event-driven webhooks', 'Workflow hardening', 'Operational runbooks'],
	'Data / Search': ['Search index design', 'Ingestion pipelines', 'Schema governance', 'Faceted query strategy'],
	Frontend: ['Astro', 'TypeScript', 'React islands', 'Performance-first UI'],
};
---

<MainLayout title="Taj | Solutions Architect" description="Solutions Architect focused on edge, automation, and data platform architecture.">
	<Container size="wide">
		<section class="hero section">
			<div class="hero__layout">
				<div class="hero__content">
					<p class="hero__eyebrow">Solutions Architect · Edge, Automation &amp; Data Platforms</p>
					<h1>Tajinder Singh</h1>
					<p class="hero__mission">
						I design verification-first, automation-driven platform architectures that reduce operational
						friction, harden edge entry points, and move data reliably from edge events into
						production systems.
					</p>
					<div class="hero__actions">
						<ButtonLink href="/work">View Work</ButtonLink>
						<ButtonLink href="/contact" variant="secondary">Contact</ButtonLink>
					</div>
					<p class="hero__focus-title">Core Focus Areas</p>
					<div class="hero__pills">
						<PillTag label="Cloudflare Workers" />
						<PillTag label="Secure Verification Paths" />
						<PillTag label="Event-Driven Automation" />
						<PillTag label="Faceted Search Architecture" />
						<PillTag label="Data Pipelines" />
					</div>
				</div>
				<figure class="hero__avatar" aria-hidden="true">
					<img
						src="/images/tajinder-singh-portrait.jpg"
						alt=""
						loading="lazy"
						width="220"
						height="220"
					/>
				</figure>
			</div>
		</section>

		<section class="section">
			<SectionHeading
				eyebrow="Work"
				title="Featured Case Studies"
				description="Selected implementations with measurable operational impact."
			/>
			{featured.length ? (
				<ul class="grid grid--cards">
					{featured.map((item) => (
						<li>
							<ProjectCard
								title={item.data.title}
								description={item.data.description}
								tags={item.data.tags}
								href={`/work/${item.id.replace(/\.(md|mdx)$/i, '')}/`}
							/>
						</li>
					))}
				</ul>
			) : (
				<p class="section-intro">New case studies coming soon. In the meantime, browse all work.</p>
			)}
		</section>

		<section class="section">
			<SectionHeading eyebrow="What I Do" title="Architecture Domains" />
			<div class="grid grid--three">
				<article class="info-card">
					<h3>Edge &amp; Verification Architecture</h3>
					<p>
						Workers-based routing, request validation, and hardened verification paths designed to stop
						abuse before it reaches origin systems.
					</p>
				</article>
				<article class="info-card">
					<h3>Automation &amp; Orchestration</h3>
					<p>
						Event-driven workflows that replace brittle manual operations with resilient, observable
						automation pipelines.
					</p>
				</article>
				<article class="info-card">
					<h3>Search &amp; Data Platforms</h3>
					<p>
						Structured ingestion architecture, schema governance, and faceted discovery systems that scale
						beyond CMS or browser constraints.
					</p>
				</article>
			</div>
		</section>

		<section class="section">
			<SectionHeading eyebrow="Selected Technology" title="Platform-Fit Tooling" />
			<p class="section-intro">
				I work across platform boundaries, selecting tools based on architectural fit rather than trend
				alignment.
			</p>
			<div class="grid grid--stack">
				{
					Object.entries(techGroups).map(([group, tech]) => (
						<section class="tech-group">
							<h3>{group}</h3>
							<div class="tech-group__items">
								{tech.map((item) => <PillTag label={item} />)}
							</div>
						</section>
					))
				}
			</div>
		</section>

		<section class="section now">
			<SectionHeading eyebrow="Now" title="Currently Building" />
			<p>
				Designing verification-first edge pipelines that connect Cloudflare entry points to orchestration
				systems and downstream data services, with tighter observability, replay protection, and
				safer routing rules.
			</p>
		</section>

		<section class="section contact-cta">
			<SectionHeading eyebrow="Contact" title="Let's Build Useful Systems" />
			<p>
				If you are shipping automation-heavy products or edge-first platforms, I can help design
				infrastructure that scales with fewer surprises.
			</p>
			<div class="contact-links">
				<a href="mailto:contact@tajs.io">contact@tajs.io</a>
				<a href="https://www.linkedin.com/in/taj-tajinder/" target="_blank" rel="noreferrer">LinkedIn</a>
			</div>
		</section>
	</Container>
</MainLayout>

<style>
	.section {
		margin-bottom: clamp(2.5rem, 6vw, 5rem);
	}

	.hero {
		padding: clamp(1.1rem, 3vw, 2rem);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: color-mix(in srgb, var(--color-bg-elevated) 90%, transparent);
	}

	.hero__layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: start;
	}

	.hero__eyebrow {
		margin: 0 0 0.85rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.09em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.hero h1 {
		margin: 0;
		font-size: clamp(2.5rem, 1.9rem + 3vw, 4.4rem);
	}

	.hero__mission {
		max-width: 52rem;
		font-size: 1.05rem;
		margin: 1rem 0 1.2rem;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-bottom: 0.9rem;
	}

	.hero__focus-title {
		margin: 0 0 0.55rem;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.hero__pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.hero__avatar {
		margin: 0;
		width: clamp(5.2rem, 10vw, 7rem);
		height: clamp(5.2rem, 10vw, 7rem);
		padding: 0.22rem;
		border-radius: 999px;
		border: 1px solid var(--color-border);
		background: color-mix(in srgb, var(--color-bg-elevated) 95%, transparent);
	}

	.hero__avatar img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 999px;
	}

	.section-intro {
		margin: -0.5rem 0 1rem;
		max-width: 58rem;
	}

	.grid {
		display: grid;
		gap: 1rem;
	}

	.grid--cards {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.grid--three {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.grid--stack {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.info-card,
	.tech-group,
	.contact-cta,
	.now {
		padding: 1.15rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background: color-mix(in srgb, var(--color-bg-elevated) 90%, transparent);
	}

	.info-card h3,
	.tech-group h3 {
		margin: 0 0 0.55rem;
		font-size: 1.1rem;
	}

	.info-card p {
		margin: 0;
	}

	.tech-group__items {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.contact-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 1rem;
	}

	.contact-links a {
		font-weight: 700;
		text-decoration: none;
	}

	@media (max-width: 980px) {
		.grid--cards,
		.grid--three,
		.grid--stack {
			grid-template-columns: 1fr;
		}

		.hero__layout {
			grid-template-columns: 1fr;
		}

		.hero__avatar {
			display: none;
		}
	}
</style>

