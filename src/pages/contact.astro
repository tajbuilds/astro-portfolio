---
import MainLayout from '../layouts/MainLayout.astro';
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ButtonLink from '../components/ButtonLink.astro';
import { TURNSTILE_SITE_KEY } from '../consts';

export const prerender = false;

const turnstileSiteKey = TURNSTILE_SITE_KEY;

const conversationAreas = [
	'Platform rebuilds and modernization work',
	'Verification and intake architecture',
	'Automation-heavy workflows and service handoffs',
	'Search, retrieval, or data movement design',
];

const directLinks = [
	{
		label: 'Email',
		href: 'mailto:contact@tajs.io',
		icon: 'email',
	},
	{
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/in/taj-tajinder/',
		icon: 'linkedin',
	},
	{
		label: 'GitHub',
		href: 'https://github.com/tajbuilds',
		icon: 'github',
	},
	{
		label: 'Google Play',
		href: 'https://play.google.com/store/apps/details?id=com.tajbuilds.portfolio',
		icon: 'play',
	},
];
---

<MainLayout title="Contact | Tajinder Singh" description="Get in touch with Tajinder Singh for architecture and automation projects.">
	<Container size="wide">
		<section class="contact-hero">
			<div class="contact-hero__copy">
				<p class="contact-hero__kicker" data-reveal="soft">Contact · Architecture Conversations</p>
				<h1 data-reveal="soft">Planning a platform rebuild, designing a better intake path, or trying to remove friction from a system that has grown harder to operate?</h1>
				<p class="contact-hero__support" data-reveal="soft">
					I am open to conversations where the problem is architectural, operational, or system-level rather
					than purely cosmetic. That usually means entry-point control, automation workflows, search systems,
					service integration, or a delivery path that needs clearer structure.
				</p>
				<div class="contact-hero__actions" data-reveal="soft">
					<ButtonLink href="/work">See Relevant Work</ButtonLink>
					<ButtonLink href="mailto:contact@tajs.io" variant="secondary">Email Directly</ButtonLink>
				</div>
			</div>

			<aside class="contact-hero__aside" data-reveal="right">
				<div class="contact-summary">
					<p class="contact-summary__label">Good fit for</p>
					<ul>
						{conversationAreas.map((item) => <li>{item}</li>)}
					</ul>
				</div>
				<div class="contact-summary contact-summary--quiet">
					<p class="contact-summary__label">What helps</p>
					<p>
						If you already know the current constraint, affected system, and what “better” needs to look like,
						share that context up front. It makes the conversation more useful, faster.
					</p>
				</div>
			</aside>
		</section>

		<section class="contact-layout">
			<div class="contact-layout__main" data-reveal="soft">
				<div class="contact-form-shell">
					<SectionHeading
						eyebrow="Start Here"
						title="Describe the problem, the current system, and what needs to improve."
						description="This page is meant for meaningful architecture conversations, not generic outreach. If the work involves system structure, delivery paths, or platform reliability, send context."
					/>

					<form id="contact-form" class="contact-form" method="post" action="/api/contact" novalidate>
						<label>
							<span>Name</span>
							<input name="name" type="text" autocomplete="name" required minlength="2" maxlength="120" />
						</label>

						<label>
							<span>Email</span>
							<input name="email" type="email" autocomplete="email" required maxlength="190" />
						</label>

						<label>
							<span>Message</span>
							<textarea name="message" rows="7" required></textarea>
						</label>

						<input class="honeypot" type="text" name="company" tabindex="-1" autocomplete="off" />

						<div class="verification-row">
							<div class="actions">
								<button type="submit">Send message</button>
								<p id="contact-status" class="status" role="status" aria-live="polite"></p>
							</div>

							{turnstileSiteKey ? (
								<div class="turnstile-wrap">
									<div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
								</div>
							) : (
								<p class="config-warning">Turnstile site key is not configured yet.</p>
							)}
						</div>
					</form>
				</div>
			</div>

			<aside class="contact-layout__rail">
				<section class="contact-rail-card" data-reveal="soft">
					<p class="contact-rail-card__eyebrow">Direct Contact</p>
					<h2>Reach out through the channel that fits best.</h2>
					<div class="contact-meta" aria-label="Contact links">
						<img
							class="contact-avatar"
							src="/images/tajinder-singh-portrait.jpg"
							alt="Portrait of Tajinder Singh"
							loading="lazy"
							width="52"
							height="52"
						/>
						<div class="contact-links">
							{directLinks.map((item) => (
								<a
									class="contact-icon-link"
									href={item.href}
									target={item.href.startsWith('http') ? '_blank' : undefined}
									rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
									aria-label={item.label}
									title={item.label}
								>
									{item.icon === 'email' && (
										<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
											<path d="M3 6h18v12H3z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
											<path d="M3 7l9 7 9-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
										</svg>
									)}
									{item.icon === 'linkedin' && (
										<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
											<path d="M4 9h4v11H4zM6 4a2 2 0 110 4 2 2 0 010-4zM11 9h4v1.8c.8-1.3 1.9-2.2 4.1-2.2 3.3 0 4.9 2.1 4.9 6V20h-4v-4.7c0-2.2-.8-3-2.2-3-1.6 0-2.8 1.1-2.8 3.1V20h-4z" fill="currentColor"/>
										</svg>
									)}
									{item.icon === 'github' && (
										<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
											<path
												fill="currentColor"
												d="M12 2a10 10 0 00-3.162 19.487c.5.093.683-.217.683-.482 0-.238-.009-.87-.013-1.707-2.781.604-3.369-1.34-3.369-1.34-.455-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.004.071 1.532 1.031 1.532 1.031.893 1.531 2.343 1.089 2.914.833.091-.647.35-1.09.636-1.341-2.221-.253-4.555-1.11-4.555-4.941 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.271.098-2.649 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844a9.56 9.56 0 012.504.337c1.909-1.294 2.748-1.025 2.748-1.025.546 1.378.203 2.396.1 2.649.64.699 1.028 1.592 1.028 2.683 0 3.84-2.338 4.685-4.566 4.933.359.309.679.92.679 1.854 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.481A10 10 0 0012 2z"
											/>
										</svg>
									)}
									{item.icon === 'play' && (
										<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
											<path
												fill="currentColor"
												d="M3 20.6V3.4c0-.8.8-1.3 1.5-.9L18.8 10.7c.7.4.7 1.3 0 1.7L4.5 21.5c-.7.4-1.5-.1-1.5-.9Z"
											/>
										</svg>
									)}
									<span class="sr-only">{item.label}</span>
								</a>
							))}
						</div>
					</div>
				</section>

				<section class="contact-rail-card contact-rail-card--note" data-reveal="soft">
					<p class="contact-rail-card__eyebrow">Best conversations</p>
					<p>
						The most useful enquiries usually describe the current architecture, the friction point, and what
						needs to become more predictable, faster, safer, or easier to operate.
					</p>
				</section>
			</aside>
		</section>
	</Container>
	{turnstileSiteKey && (
		<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
	)}
</MainLayout>

<script is:inline>
	(() => {
		const form = document.getElementById('contact-form');
		const statusEl = document.getElementById('contact-status');
		if (!(form instanceof HTMLFormElement) || !(statusEl instanceof HTMLElement)) return;

		const setStatus = (message, isError = false) => {
			statusEl.textContent = message;
			statusEl.dataset.error = isError ? 'true' : 'false';
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			setStatus('Sending...');

			const formData = new FormData(form);
			const payload = {
				name: String(formData.get('name') || ''),
				email: String(formData.get('email') || ''),
				message: String(formData.get('message') || ''),
				company: String(formData.get('company') || ''),
				turnstileToken: String(formData.get('cf-turnstile-response') || ''),
			};

			if (payload.name.trim().length < 2) {
				setStatus('Please enter your full name (at least 2 characters).', true);
				return;
			}

			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(payload.email.trim())) {
				setStatus('Please enter a valid email address.', true);
				return;
			}

			if (!payload.message.trim()) {
				setStatus('Please enter your message.', true);
				return;
			}

			try {
				const response = await fetch('/api/contact', {
					method: 'POST',
					body: JSON.stringify(payload),
					headers: {
						Accept: 'application/json',
						'content-type': 'application/json',
					},
				});

				const responsePayload = await response
					.json()
					.catch(() => ({ ok: false, message: 'Unexpected response.' }));

				if (!response.ok || !responsePayload.ok) {
					setStatus(responsePayload.message || 'Unable to send message.', true);
					return;
				}

				form.reset();
				if (window.turnstile && typeof window.turnstile.reset === 'function') {
					window.turnstile.reset();
				}
				setStatus(responsePayload.message || 'Message sent.');
			} catch {
				setStatus('Network error. Please try again.', true);
			}
		});
	})();
</script>

<style>
	.contact-hero,
	.contact-form-shell,
	.contact-rail-card {
		border: 1px solid color-mix(in srgb, var(--color-accent) 18%, var(--color-border));
		border-radius: calc(var(--radius-lg) - 0.1rem);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--color-bg-elevated) 95%, transparent), color-mix(in srgb, var(--color-bg-elevated) 90%, transparent)),
			radial-gradient(circle at top right, color-mix(in srgb, var(--color-accent) 10%, transparent), transparent 36%);
		box-shadow: var(--shadow-sm);
	}

	.contact-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.9fr);
		gap: 1rem;
		align-items: start;
		padding: clamp(1.2rem, 2vw, 1.8rem);
		margin-bottom: clamp(2rem, 4vw, 3.2rem);
	}

	.contact-hero__copy {
		display: grid;
		gap: 1rem;
		max-width: 44rem;
	}

	.contact-hero__kicker,
	.contact-summary__label,
	.contact-rail-card__eyebrow {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.contact-hero h1 {
		margin: 0;
		font-size: clamp(2.5rem, 1.9rem + 2.7vw, 4.2rem);
		line-height: 0.98;
		max-width: 15ch;
	}

	.contact-hero__support {
		margin: 0;
		max-width: 42rem;
		font-size: 1rem;
	}

	.contact-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
	}

	.contact-hero__aside {
		display: grid;
		gap: 0.85rem;
	}

	.contact-summary {
		padding: 1rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background: color-mix(in srgb, var(--color-bg-elevated) 88%, transparent);
	}

	.contact-summary ul {
		margin: 0.7rem 0 0;
		padding-left: 1.1rem;
		display: grid;
		gap: 0.5rem;
	}

	.contact-summary--quiet p:last-child {
		margin: 0.45rem 0 0;
	}

	.contact-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
		gap: 1rem;
		align-items: start;
	}

	.contact-layout__main,
	.contact-layout__rail {
		min-width: 0;
	}

	.contact-layout__rail {
		display: grid;
		gap: 1rem;
	}

	.contact-form-shell {
		padding: clamp(1.15rem, 2vw, 1.6rem);
		box-shadow: var(--shadow-md);
	}

	.contact-form-shell :global(.section-heading) {
		margin-bottom: 1.1rem;
	}

	.contact-form {
		display: grid;
		gap: 0.9rem;
	}

	.contact-form label {
		display: grid;
		gap: 0.35rem;
	}

	.contact-form span {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--color-text);
	}

	.contact-form input,
	.contact-form textarea {
		width: 100%;
		padding: 0.72rem 0.78rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg-elevated);
		color: var(--color-text);
		font: inherit;
		transition:
			border-color var(--motion-fast) var(--ease-standard),
			box-shadow var(--motion-fast) var(--ease-standard);
	}

	.contact-form input:focus,
	.contact-form textarea:focus {
		border-color: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 14%, transparent);
		outline: none;
	}

	.contact-form textarea {
		resize: vertical;
		min-height: 10rem;
	}

	.verification-row {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.35rem;
	}

	.turnstile-wrap {
		display: flex;
		justify-content: flex-end;
	}

	.actions {
		display: grid;
		gap: 0.45rem;
	}

	.contact-form button {
		width: fit-content;
		border: 1px solid var(--color-accent);
		background: var(--color-accent);
		color: #fff;
		border-radius: 999px;
		padding: 0.56rem 1rem;
		font: inherit;
		font-weight: 700;
		cursor: pointer;
		transition:
			transform var(--motion-fast) var(--ease-standard),
			background-color var(--motion-fast) var(--ease-standard),
			box-shadow var(--motion-base) var(--ease-standard);
	}

	.contact-form button:hover {
		transform: translateY(-1px);
		background: var(--color-accent-strong);
		box-shadow: var(--shadow-sm);
	}

	.status {
		margin: 0;
		font-size: 0.9rem;
		color: var(--color-text-muted);
	}

	.status[data-error='true'] {
		color: #ef4444;
	}

	.config-warning {
		margin: 0;
		font-size: 0.9rem;
		color: #ef4444;
	}

	.contact-rail-card {
		display: grid;
		gap: 0.85rem;
		padding: 1rem;
	}

	.contact-rail-card h2,
	.contact-rail-card p {
		margin: 0;
	}

	.contact-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		flex-wrap: wrap;
	}

	.contact-avatar {
		width: 2.6rem;
		height: 2.6rem;
		object-fit: cover;
		border-radius: 999px;
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-sm);
		flex: 0 0 auto;
	}

	.contact-links {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		flex-wrap: wrap;
	}

	.contact-icon-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--color-accent);
		text-decoration: none;
		padding: 0.22rem;
		border-radius: 0.35rem;
		border: 1px solid transparent;
		transition:
			color var(--motion-fast) var(--ease-standard),
			transform var(--motion-fast) var(--ease-standard),
			border-color var(--motion-fast) var(--ease-standard),
			background-color var(--motion-fast) var(--ease-standard);
	}

	.contact-icon-link:hover {
		color: var(--color-accent-strong);
		transform: translateY(-1px);
		border-color: color-mix(in srgb, var(--color-accent) 24%, transparent);
		background: color-mix(in srgb, var(--color-accent) 8%, transparent);
	}

	.contact-icon-link:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.contact-icon-link svg {
		width: 1.15rem;
		height: 1.15rem;
	}

	.honeypot {
		position: absolute;
		left: -9999px;
		opacity: 0;
		pointer-events: none;
	}

	@media (max-width: 1040px) {
		.contact-hero,
		.contact-layout {
			grid-template-columns: 1fr;
		}

		.contact-hero h1 {
			max-width: none;
		}
	}

	@media (max-width: 900px) {
		.verification-row {
			flex-direction: column;
			align-items: flex-start;
		}

		.turnstile-wrap {
			justify-content: flex-start;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.contact-form button,
		.contact-icon-link {
			transition: none;
		}

		.contact-form button:hover,
		.contact-icon-link:hover {
			transform: none;
		}
	}
</style>
