---
import MainLayout from '../layouts/MainLayout.astro';
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';

export const prerender = false;

const turnstileSiteKey = Astro.locals.runtime.env.TURNSTILE_SITE_KEY ?? '';
---

<MainLayout title="Contact | Tajinder Singh" description="Get in touch with Tajinder Singh for architecture and automation projects.">
	<Container size="narrow">
		<section class="contact-page">
			<SectionHeading
				eyebrow="Contact"
				title="Discuss Your Platform Architecture"
				description="Share your current system, constraints, and timeline. I can help map an implementation path."
			/>

			<div class="contact-card">
				<form id="contact-form" class="contact-form" method="post" action="/api/contact" novalidate>
					<label>
						<span>Name</span>
						<input name="name" type="text" autocomplete="name" required minlength="2" maxlength="120" />
					</label>

					<label>
						<span>Email</span>
						<input name="email" type="email" autocomplete="email" required maxlength="190" />
					</label>

					<label>
						<span>Message</span>
						<textarea name="message" rows="6" required minlength="30" maxlength="2500"></textarea>
						<small class="field-hint">Minimum 30 characters and 29 words.</small>
					</label>

					<input class="honeypot" type="text" name="company" tabindex="-1" autocomplete="off" />

					<div class="verification-row">
						<div class="actions">
							<button type="submit">Send message</button>
							<p id="contact-status" class="status" role="status" aria-live="polite"></p>
						</div>

						{turnstileSiteKey ? (
							<div class="turnstile-wrap">
								<div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
							</div>
						) : (
							<p class="config-warning">Turnstile site key is not configured yet.</p>
						)}
					</div>
				</form>

				<div class="contact-meta">
					<img
						class="contact-avatar"
						src="/images/tajinder-singh-portrait.jpg"
						alt="Portrait of Tajinder Singh"
						loading="lazy"
						width="44"
						height="44"
					/>
					<ul class="contact-links">
						<li><a href="mailto:contact@tajs.io">contact@tajs.io</a></li>
						<li><a href="https://www.linkedin.com/in/taj-tajinder/" target="_blank" rel="noreferrer">LinkedIn</a></li>
					</ul>
				</div>
			</div>
		</section>
	</Container>
</MainLayout>

<script is:inline>
	(() => {
		const form = document.getElementById('contact-form');
		const statusEl = document.getElementById('contact-status');
		if (!(form instanceof HTMLFormElement) || !(statusEl instanceof HTMLElement)) return;

		const MIN_MESSAGE_CHARS = 30;
		const MIN_MESSAGE_WORDS = 29;
		const wordCount = (value) => value.trim().split(/\s+/).filter(Boolean).length;

		const setStatus = (message, isError = false) => {
			statusEl.textContent = message;
			statusEl.dataset.error = isError ? 'true' : 'false';
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			setStatus('Sending...');

			const formData = new FormData(form);
			const payload = {
				name: String(formData.get('name') || ''),
				email: String(formData.get('email') || ''),
				message: String(formData.get('message') || ''),
				company: String(formData.get('company') || ''),
				turnstileToken: String(formData.get('cf-turnstile-response') || ''),
			};

			if (payload.name.trim().length < 2) {
				setStatus('Please enter your full name (at least 2 characters).', true);
				return;
			}

			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(payload.email.trim())) {
				setStatus('Please enter a valid email address.', true);
				return;
			}

			if (payload.message.trim().length < MIN_MESSAGE_CHARS) {
				setStatus('Please enter a message with at least 30 characters.', true);
				return;
			}

			if (wordCount(payload.message) < MIN_MESSAGE_WORDS) {
				setStatus('Please provide a bit more detail (minimum 29 words).', true);
				return;
			}

			try {
				const response = await fetch('/api/contact', {
					method: 'POST',
					body: JSON.stringify(payload),
					headers: {
						Accept: 'application/json',
						'content-type': 'application/json',
					},
				});

				const responsePayload = await response
					.json()
					.catch(() => ({ ok: false, message: 'Unexpected response.' }));

				if (!response.ok || !responsePayload.ok) {
					setStatus(responsePayload.message || 'Unable to send message.', true);
					return;
				}

				form.reset();
				if (window.turnstile && typeof window.turnstile.reset === 'function') {
					window.turnstile.reset();
				}
				setStatus(responsePayload.message || 'Message sent.');
			} catch {
				setStatus('Network error. Please try again.', true);
			}
		});
	})();
</script>

<style>
	.contact-page {
		display: grid;
		gap: 1.1rem;
	}

	.contact-card {
		padding: 1.2rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background: color-mix(in srgb, var(--color-bg-elevated) 92%, transparent);
		display: grid;
		gap: 1rem;
	}

	.contact-form {
		display: grid;
		gap: 0.85rem;
	}

	.contact-form label {
		display: grid;
		gap: 0.35rem;
	}

	.contact-form span {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--color-text);
	}

	.contact-form input,
	.contact-form textarea {
		width: 100%;
		padding: 0.62rem 0.72rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg-elevated);
		color: var(--color-text);
		font: inherit;
	}

	.contact-form textarea {
		resize: vertical;
		min-height: 8rem;
	}

	.field-hint {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		margin-top: -0.1rem;
	}

	.verification-row {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.35rem;
	}

	.turnstile-wrap {
		display: flex;
		justify-content: flex-end;
	}

	.contact-form button {
		width: fit-content;
		border: 1px solid var(--color-accent);
		background: var(--color-accent);
		color: #fff;
		border-radius: 999px;
		padding: 0.52rem 0.95rem;
		font: inherit;
		font-weight: 700;
		cursor: pointer;
	}

	.contact-form button:hover {
		background: var(--color-accent-strong);
	}

	.actions {
		display: grid;
		gap: 0.45rem;
	}

	.status {
		margin: 0;
		font-size: 0.9rem;
		color: var(--color-text-muted);
	}

	.status[data-error='true'] {
		color: #ef4444;
	}

	.config-warning {
		margin: 0;
		font-size: 0.9rem;
		color: #ef4444;
	}

	.contact-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.contact-avatar {
		width: 2.2rem;
		height: 2.2rem;
		object-fit: cover;
		border-radius: 999px;
		border: 1px solid var(--color-border);
	}

	.contact-links {
		margin: 0;
		padding-left: 1.15rem;
		display: grid;
		gap: 0.4rem;
	}

	.contact-links a {
		font-weight: 700;
	}

	.honeypot {
		position: absolute;
		left: -9999px;
		opacity: 0;
		pointer-events: none;
	}

	@media (max-width: 900px) {
		.verification-row {
			flex-direction: column;
			align-items: flex-start;
		}

		.turnstile-wrap {
			justify-content: flex-start;
		}
	}
</style>
