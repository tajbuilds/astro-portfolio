---
import MainLayout from '../layouts/MainLayout.astro';
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { TURNSTILE_SITE_KEY } from '../consts';

export const prerender = false;

const turnstileSiteKey = TURNSTILE_SITE_KEY;
---

<MainLayout title="Contact | Tajinder Singh" description="Get in touch with Tajinder Singh for architecture and automation projects.">
	<Container size="narrow">
		<section class="contact-page">
			<SectionHeading
				eyebrow="Contact"
				title="Discuss Your Platform Architecture"
				description="Share your current system, constraints, and timeline. I can help map an implementation path."
			/>

			<div class="contact-card">
				<form id="contact-form" class="contact-form" method="post" action="/api/contact" novalidate>
					<label>
						<span>Name</span>
						<input name="name" type="text" autocomplete="name" required minlength="2" maxlength="120" />
					</label>

					<label>
						<span>Email</span>
						<input name="email" type="email" autocomplete="email" required maxlength="190" />
					</label>

					<label>
						<span>Message</span>
						<textarea name="message" rows="6" required></textarea>
					</label>

					<input class="honeypot" type="text" name="company" tabindex="-1" autocomplete="off" />

					<div class="verification-row">
						<div class="actions">
							<button type="submit">Send message</button>
							<p id="contact-status" class="status" role="status" aria-live="polite"></p>
						</div>

						{turnstileSiteKey ? (
							<div class="turnstile-wrap">
								<div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
							</div>
						) : (
							<p class="config-warning">Turnstile site key is not configured yet.</p>
						)}
					</div>
				</form>

				<div class="contact-meta" aria-label="Contact links">
					<img
						class="contact-avatar"
						src="/images/tajinder-singh-portrait.jpg"
						alt="Portrait of Tajinder Singh"
						loading="lazy"
						width="44"
						height="44"
					/>
					<div class="contact-links">
						<a
							class="contact-icon-link"
							href="mailto:contact@tajs.io"
							aria-label="Email Tajinder Singh"
							title="Email"
						>
							<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
								<path d="M3 6h18v12H3z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
								<path d="M3 7l9 7 9-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
							<span class="sr-only">Email</span>
						</a>
						<a
							class="contact-icon-link"
							href="https://www.linkedin.com/in/taj-tajinder/"
							target="_blank"
							rel="noreferrer"
							aria-label="LinkedIn profile"
							title="LinkedIn"
						>
							<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
								<path d="M4 9h4v11H4zM6 4a2 2 0 110 4 2 2 0 010-4zM11 9h4v1.8c.8-1.3 1.9-2.2 4.1-2.2 3.3 0 4.9 2.1 4.9 6V20h-4v-4.7c0-2.2-.8-3-2.2-3-1.6 0-2.8 1.1-2.8 3.1V20h-4z" fill="currentColor"/>
							</svg>
							<span class="sr-only">LinkedIn</span>
						</a>
						<a
							class="contact-icon-link"
							href="https://github.com/tajbuilds"
							target="_blank"
							rel="noreferrer"
							aria-label="GitHub profile"
							title="GitHub"
						>
							<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
								<path
									fill="currentColor"
									d="M12 2a10 10 0 00-3.162 19.487c.5.093.683-.217.683-.482 0-.238-.009-.87-.013-1.707-2.781.604-3.369-1.34-3.369-1.34-.455-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.004.071 1.532 1.031 1.532 1.031.893 1.531 2.343 1.089 2.914.833.091-.647.35-1.09.636-1.341-2.221-.253-4.555-1.11-4.555-4.941 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.271.098-2.649 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844a9.56 9.56 0 012.504.337c1.909-1.294 2.748-1.025 2.748-1.025.546 1.378.203 2.396.1 2.649.64.699 1.028 1.592 1.028 2.683 0 3.84-2.338 4.685-4.566 4.933.359.309.679.92.679 1.854 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.481A10 10 0 0012 2z"
								/>
							</svg>
							<span class="sr-only">GitHub</span>
						</a>
					</div>
				</div>
			</div>
		</section>
	</Container>
{turnstileSiteKey && (
	<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}
</MainLayout>

<script is:inline>
	(() => {
		const form = document.getElementById('contact-form');
		const statusEl = document.getElementById('contact-status');
		if (!(form instanceof HTMLFormElement) || !(statusEl instanceof HTMLElement)) return;

		const setStatus = (message, isError = false) => {
			statusEl.textContent = message;
			statusEl.dataset.error = isError ? 'true' : 'false';
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			setStatus('Sending...');

			const formData = new FormData(form);
			const payload = {
				name: String(formData.get('name') || ''),
				email: String(formData.get('email') || ''),
				message: String(formData.get('message') || ''),
				company: String(formData.get('company') || ''),
				turnstileToken: String(formData.get('cf-turnstile-response') || ''),
			};

			if (payload.name.trim().length < 2) {
				setStatus('Please enter your full name (at least 2 characters).', true);
				return;
			}

			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(payload.email.trim())) {
				setStatus('Please enter a valid email address.', true);
				return;
			}

			if (!payload.message.trim()) {
				setStatus('Please enter your message.', true);
				return;
			}

			try {
				const response = await fetch('/api/contact', {
					method: 'POST',
					body: JSON.stringify(payload),
					headers: {
						Accept: 'application/json',
						'content-type': 'application/json',
					},
				});

				const responsePayload = await response
					.json()
					.catch(() => ({ ok: false, message: 'Unexpected response.' }));

				if (!response.ok || !responsePayload.ok) {
					setStatus(responsePayload.message || 'Unable to send message.', true);
					return;
				}

				form.reset();
				if (window.turnstile && typeof window.turnstile.reset === 'function') {
					window.turnstile.reset();
				}
				setStatus(responsePayload.message || 'Message sent.');
			} catch {
				setStatus('Network error. Please try again.', true);
			}
		});
	})();
</script>

<style>
	.contact-page {
		display: grid;
		gap: 1.1rem;
	}

	.contact-card {
		padding: 1.2rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background: color-mix(in srgb, var(--color-bg-elevated) 92%, transparent);
		display: grid;
		gap: 1rem;
	}

	.contact-form {
		display: grid;
		gap: 0.85rem;
	}

	.contact-form label {
		display: grid;
		gap: 0.35rem;
	}

	.contact-form span {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--color-text);
	}

	.contact-form input,
	.contact-form textarea {
		width: 100%;
		padding: 0.62rem 0.72rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg-elevated);
		color: var(--color-text);
		font: inherit;
	}

	.contact-form textarea {
		resize: vertical;
		min-height: 8rem;
	}

	.field-hint {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		margin-top: -0.1rem;
	}

	.verification-row {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.35rem;
	}

	.turnstile-wrap {
		display: flex;
		justify-content: flex-end;
	}

	.contact-form button {
		width: fit-content;
		border: 1px solid var(--color-accent);
		background: var(--color-accent);
		color: #fff;
		border-radius: 999px;
		padding: 0.52rem 0.95rem;
		font: inherit;
		font-weight: 700;
		cursor: pointer;
	}

	.contact-form button:hover {
		background: var(--color-accent-strong);
	}

	.actions {
		display: grid;
		gap: 0.45rem;
	}

	.status {
		margin: 0;
		font-size: 0.9rem;
		color: var(--color-text-muted);
	}

	.status[data-error='true'] {
		color: #ef4444;
	}

	.config-warning {
		margin: 0;
		font-size: 0.9rem;
		color: #ef4444;
	}

    .contact-meta {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        flex-wrap: nowrap;
    }

    .contact-avatar {
        width: 2.2rem;
        height: 2.2rem;
        object-fit: cover;
        border-radius: 999px;
        border: 1px solid var(--color-border);
        flex: 0 0 auto;
    }

    .contact-links {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        flex-wrap: nowrap;
        flex: 0 0 auto;
    }

	.contact-icon-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--color-accent);
		text-decoration: none;
		padding: 0.15rem;
		border-radius: 0.25rem;
		transition: color 120ms ease, opacity 120ms ease;
	}

	.contact-icon-link:hover {
		color: var(--color-accent-strong);
		opacity: 0.9;
	}

	.contact-icon-link:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.contact-icon-link svg {
		width: 1.1rem;
		height: 1.1rem;
	}

	.honeypot {
		position: absolute;
		left: -9999px;
		opacity: 0;
		pointer-events: none;
	}

	@media (max-width: 900px) {
		.verification-row {
			flex-direction: column;
			align-items: flex-start;
		}

		.turnstile-wrap {
			justify-content: flex-start;
		}
	}
</style>






