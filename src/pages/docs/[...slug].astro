---
import MainLayout from "../../layouts/MainLayout.astro";
import DocNavTree from "../../components/DocNavTree.astro";
import type { NavNode } from "../../components/DocNavTree.astro";
import { marked } from "marked";
import { env } from "cloudflare:workers";

export const prerender = false;

const slugParam = Astro.params.slug || "";
const parts = slugParam.split("/").filter(Boolean);

if (parts.length < 2 || parts[0] !== "case-studies") {
return new Response("Not found", { status: 404 });
}

const caseSlug = parts[1];
const sectionPath = parts.slice(2).join("/");

const normalizePath = (value: string | null | undefined) =>
	(value || "").trim().replace(/^\/+|\/+$/g, "");

const targetRelPath = normalizePath(sectionPath);

const db = env.DB as D1Database | undefined;
if (!db) {
return new Response("D1 binding 'DB' is missing on this environment.", { status: 500 });
}

type CaseStudyRow = {
id: string;
title: string;
slug: string;
summary: string | null;
};

type DocumentRow = {
id: string;
title: string;
slug_path: string;
parent_id: string | null;
nav_order: number;
depth: number;
is_root: number;
body_md: string;
excerpt: string | null;
created_at: string;
};

const caseStudy = await db
.prepare(
`SELECT id, title, slug, summary
 FROM case_studies
 WHERE slug = ?1
	 AND is_visible = 1
	 AND source_collection_id = (
				SELECT oc.id
				FROM outline_collections oc
				WHERE oc.slug = 'case-studies'
					AND oc.is_visible = 1
				ORDER BY oc.nav_order ASC, oc.updated_at DESC
				LIMIT 1
	 )
 LIMIT 1`
)
.bind(caseSlug)
.first<CaseStudyRow>();

if (!caseStudy) return new Response("Not found", { status: 404 });

const docsResult = await db
.prepare(
`SELECT id, title, slug_path, parent_id, nav_order, depth, is_root, body_md, excerpt, created_at
 FROM documents
 WHERE case_study_id = ?1
 ORDER BY depth ASC, COALESCE(parent_id, ''), nav_order ASC, created_at ASC, title ASC`
)
.bind(caseStudy.id)
.all<DocumentRow>();

const docs = docsResult.results || [];

const getDocRelPath = (doc: DocumentRow) => {
	const slugPath = normalizePath(doc.slug_path);
	if (!slugPath) return "";
	if (slugPath === caseSlug) return "";
	if (slugPath.startsWith(`${caseSlug}/`)) return slugPath.slice(caseSlug.length + 1);
	return slugPath;
};

const currentDoc = targetRelPath
	? docs.find((d) => getDocRelPath(d) === targetRelPath)
			|| docs.find((d) => normalizePath(d.slug_path).endsWith(`/${targetRelPath}`))
	: docs.find((d) => normalizePath(d.slug_path) === caseSlug)
			|| docs.find((d) => d.is_root === 1)
			|| docs.find((d) => d.depth === 0);

if (!currentDoc) return new Response("Not found", { status: 404 });

const toLink = (slugPath: string) => {
const normalized = normalizePath(slugPath);
if (!normalized || normalized === caseSlug) return `/docs/case-studies/${caseSlug}/`;
const rel = normalized.startsWith(`${caseSlug}/`)
	? normalized.slice(caseSlug.length + 1)
	: normalized;
return rel ? `/docs/case-studies/${caseSlug}/${rel}/` : `/docs/case-studies/${caseSlug}/`;
};

const buildTree = (allDocs: DocumentRow[]): NavNode[] => {
const map = new Map<string, NavNode>();
for (const d of allDocs) {
map.set(d.id, { id: d.id, title: d.title, slug_path: d.slug_path, nav_order: d.nav_order, children: [] });
}
const roots: NavNode[] = [];
for (const d of allDocs) {
const node = map.get(d.id)!;
if (d.parent_id && d.parent_id !== d.id && map.has(d.parent_id)) {
map.get(d.parent_id)!.children.push(node);
} else {
roots.push(node);
}
}
return roots;
};

const navTree = buildTree(docs);

const sectionSegments =
getDocRelPath(currentDoc)
	? getDocRelPath(currentDoc).split("/").filter(Boolean)
	: [];

const breadcrumbs: { label: string; href: string }[] = [
{ label: "Docs", href: "/docs/" },
{ label: caseStudy.title, href: `/docs/case-studies/${caseSlug}/` },
];
for (let i = 0; i < sectionSegments.length; i++) {
const sp = `${caseSlug}/${sectionSegments.slice(0, i + 1).join("/")}`;
const rel = sectionSegments.slice(0, i + 1).join("/");
const doc = docs.find((d) => getDocRelPath(d) === rel)
	|| docs.find((d) => normalizePath(d.slug_path) === sp);
if (doc) breadcrumbs.push({ label: doc.title, href: toLink(sp) });
}

const byId = new Map(docs.map((d) => [d.id, d] as const));
const flatOrdered: DocumentRow[] = [];
const walk = (nodes: NavNode[]) => {
for (const node of nodes) {
const row = byId.get(node.id);
if (row) flatOrdered.push(row);
if (node.children.length) walk(node.children);
}
};
walk(navTree);
const currentIdx = flatOrdered.findIndex((d) => d.id === currentDoc.id);
const prevDoc = currentIdx > 0 ? flatOrdered[currentIdx - 1] : null;
const nextDoc = currentIdx < flatOrdered.length - 1 ? flatOrdered[currentIdx + 1] : null;

const bodyHtml = await marked.parse(currentDoc.body_md || "");
const summaryText = currentDoc.excerpt || caseStudy.summary || "Extended architecture notes, implementation decisions, and delivery context for this case study.";
---

<MainLayout
title={`${currentDoc.title} | ${caseStudy.title}`}
description={currentDoc.excerpt || caseStudy.summary || "Case study documentation"}
type="article"
width="full"
mainClass="docs-pg"
>
<div class="docs-shell">

<aside class="docs-sidebar surface-card surface-card--soft" data-reveal="left">
<div class="docs-sidebar__inner">
<a href="/docs/" class="docs-back-link">
<svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
<path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
All docs
</a>

<div class="docs-sidebar__section">
<p class="docs-sidebar__eyebrow">Case Study</p>
<strong class="docs-sidebar__title">{caseStudy.title}</strong>
</div>

<div class="docs-search" data-doc-search-root>
<label for="docs-search-input" class="sr-only">Search docs</label>
<input
id="docs-search-input"
type="search"
placeholder="Search docs&#8230;"
autocomplete="off"
data-doc-search-input
/>
<div class="docs-search-results" data-doc-search-results hidden></div>
</div>

<nav aria-label="Case study navigation">
<ul class="docs-nav-tree">
<DocNavTree nodes={navTree} currentSlugPath={currentDoc.slug_path} toLink={toLink} />
</ul>
</nav>
</div>
</aside>

<div class="docs-body">
<article class="docs-article surface-card surface-card--standard" data-reveal="soft">

{breadcrumbs.length > 1 && (
<nav class="docs-breadcrumbs" aria-label="Breadcrumb">
<ol>
{breadcrumbs.map((crumb, i) => (
<li>
{i === breadcrumbs.length - 1 ? (
<span aria-current="page">{crumb.label}</span>
) : (
<a href={crumb.href}>{crumb.label}</a>
)}
</li>
))}
</ol>
</nav>
)}

<header class="docs-hero">
<p class="docs-hero__kicker">Extended Case Study</p>
<h1 class="docs-page-title">{currentDoc.title}</h1>
<p class="docs-hero__summary">{summaryText}</p>
<div class="docs-hero__meta" aria-label="Document metadata">
<span>{docs.length} sections</span>
<span>{currentDoc.depth === 0 ? "Overview" : `Depth ${currentDoc.depth}`}</span>
<span>D1 mirror</span>
</div>
</header>

<div class="docs-prose" data-doc-content>
<Fragment set:html={bodyHtml} />
</div>

{(prevDoc || nextDoc) && (
<nav class="docs-pager" aria-label="Pagination">
{prevDoc ? (
<a href={toLink(prevDoc.slug_path)} class="docs-pager__item docs-pager__item--prev">
<span class="docs-pager__dir">&#8592; Previous</span>
<span class="docs-pager__label">{prevDoc.title}</span>
</a>
) : <span />}
{nextDoc ? (
<a href={toLink(nextDoc.slug_path)} class="docs-pager__item docs-pager__item--next">
<span class="docs-pager__dir">Next &#8594;</span>
<span class="docs-pager__label">{nextDoc.title}</span>
</a>
) : <span />}
</nav>
)}
</article>
</div>

<aside class="docs-toc surface-card surface-card--soft" aria-label="On this page" data-doc-rail data-reveal="right">
<p class="docs-toc__label">On this page</p>
<ul class="docs-toc__list" data-doc-toc-list></ul>
</aside>

</div>

<dialog id="docs-diagram-lightbox" class="docs-diagram-lightbox" aria-label="Expanded diagram view">
<div class="docs-diagram-lightbox__panel" role="document">
<div class="docs-diagram-lightbox__toolbar">
<div class="docs-diagram-lightbox__hint">Scroll to zoom, drag to move</div>
<div class="docs-diagram-lightbox__controls">
<button type="button" data-zoom-out aria-label="Zoom out">-</button>
<button type="button" data-zoom-reset aria-label="Reset zoom">Reset</button>
<button type="button" data-zoom-in aria-label="Zoom in">+</button>
<button type="button" data-close aria-label="Close viewer">Close</button>
</div>
</div>
<div class="docs-diagram-lightbox__viewport" data-viewport>
<img data-image alt="Expanded diagram" draggable="false" />
</div>
</div>
</dialog>
</MainLayout>

<script is:inline>
(() => {
const content = document.querySelector('[data-doc-content]');
const tocList = document.querySelector('[data-doc-toc-list]');
const rail = document.querySelector('[data-doc-rail]');
if (
!(content instanceof HTMLElement) ||
!(tocList instanceof HTMLElement) ||
!(rail instanceof HTMLElement)
) return;

const slugCounts = new Map();
const slugify = (value) => {
const base = value.toLowerCase().trim()
.replace(/[^a-z0-9\s-]/g, '')
.replace(/\s+/g, '-')
.replace(/-+/g, '-') || 'section';
const seen = slugCounts.get(base) || 0;
slugCounts.set(base, seen + 1);
return seen === 0 ? base : `${base}-${seen}`;
};

const headings = Array.from(content.querySelectorAll('h2, h3'));
if (headings.length === 0) { rail.classList.add('is-empty'); return; }

const items = headings.map((heading) => {
if (!heading.id) heading.id = slugify(heading.textContent || 'section');
const li = document.createElement('li');
if (heading.tagName.toLowerCase() === 'h3') li.classList.add('is-sub');
const link = document.createElement('a');
link.href = '#' + heading.id;
link.textContent = (heading.textContent || '').trim();
li.appendChild(link);
tocList.appendChild(li);
return { heading, link };
});

if (!('IntersectionObserver' in window)) return;

const observer = new IntersectionObserver(
(entries) => {
const visible = entries
.filter((e) => e.isIntersecting)
.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
if (visible.length === 0) return;
const activeId = visible[0].target.id;
items.forEach(({ heading, link }) => {
if (heading.id === activeId) link.setAttribute('aria-current', 'true');
else link.removeAttribute('aria-current');
});
},
{ rootMargin: '-12% 0px -75% 0px', threshold: [0, 1] }
);

items.forEach(({ heading }) => observer.observe(heading));
})();
</script>

<script is:inline>
(() => {
const prose = document.querySelector('[data-doc-content]');
const dialog = document.getElementById('docs-diagram-lightbox');
if (!(prose instanceof HTMLElement) || !(dialog instanceof HTMLDialogElement)) return;

const img = dialog.querySelector('[data-image]');
const viewport = dialog.querySelector('[data-viewport]');
const closeBtn = dialog.querySelector('[data-close]');
const zoomInBtn = dialog.querySelector('[data-zoom-in]');
const zoomOutBtn = dialog.querySelector('[data-zoom-out]');
const zoomResetBtn = dialog.querySelector('[data-zoom-reset]');

if (!(img instanceof HTMLImageElement) || !(viewport instanceof HTMLElement)) return;

let scale = 1;
let tx = 0;
let ty = 0;
let dragging = false;
let lastX = 0;
let lastY = 0;

const MIN_SCALE = 1;
const MAX_SCALE = 6;
const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

const applyTransform = () => {
img.style.transform = `translate3d(${tx}px, ${ty}px, 0) scale(${scale})`;
};

const resetTransform = () => {
scale = 1;
tx = 0;
ty = 0;
applyTransform();
};

const setScale = (nextScale) => {
const clamped = clamp(nextScale, MIN_SCALE, MAX_SCALE);
if (clamped === MIN_SCALE) {
tx = 0;
ty = 0;
}
scale = clamped;
applyTransform();
};

const openLightbox = (sourceImg) => {
img.src = sourceImg.currentSrc || sourceImg.src;
img.alt = sourceImg.alt || 'Expanded diagram';
resetTransform();
if (typeof dialog.showModal === 'function') {
dialog.showModal();
} else {
dialog.setAttribute('open', '');
dialog.classList.add('is-open');
}
};

const closeLightbox = () => {
if (dialog.open && typeof dialog.close === 'function') {
dialog.close();
return;
}
dialog.removeAttribute('open');
dialog.classList.remove('is-open');
img.src = '';
resetTransform();
};

prose.querySelectorAll('img').forEach((sourceImg) => {
sourceImg.classList.add('docs-zoomable-diagram');
sourceImg.setAttribute('tabindex', '0');
sourceImg.setAttribute('role', 'button');
sourceImg.setAttribute('aria-label', 'Open expanded diagram');
});

prose.addEventListener('click', (event) => {
const sourceImg = event.target instanceof Element ? event.target.closest('img') : null;
if (!(sourceImg instanceof HTMLImageElement) || !prose.contains(sourceImg)) return;

event.preventDefault();
event.stopPropagation();
openLightbox(sourceImg);
});

prose.addEventListener('keydown', (event) => {
const sourceImg = event.target instanceof Element ? event.target.closest('img') : null;
if (!(sourceImg instanceof HTMLImageElement) || !prose.contains(sourceImg)) return;

if (event.key === 'Enter' || event.key === ' ') {
event.preventDefault();
event.stopPropagation();
openLightbox(sourceImg);
}
});

viewport.addEventListener('wheel', (event) => {
event.preventDefault();
const delta = event.deltaY < 0 ? 0.18 : -0.18;
setScale(scale + delta);
}, { passive: false });

viewport.addEventListener('pointerdown', (event) => {
if (scale <= 1) return;
dragging = true;
lastX = event.clientX;
lastY = event.clientY;
viewport.setPointerCapture(event.pointerId);
viewport.classList.add('is-dragging');
});

viewport.addEventListener('pointermove', (event) => {
if (!dragging) return;
const dx = event.clientX - lastX;
const dy = event.clientY - lastY;
lastX = event.clientX;
lastY = event.clientY;
tx += dx;
ty += dy;
applyTransform();
});

const stopDrag = (event) => {
if (!dragging) return;
dragging = false;
viewport.classList.remove('is-dragging');
if (event && viewport.hasPointerCapture(event.pointerId)) {
viewport.releasePointerCapture(event.pointerId);
}
};

viewport.addEventListener('pointerup', stopDrag);
viewport.addEventListener('pointercancel', stopDrag);
viewport.addEventListener('pointerleave', stopDrag);

zoomInBtn?.addEventListener('click', () => setScale(scale + 0.3));
zoomOutBtn?.addEventListener('click', () => setScale(scale - 0.3));
zoomResetBtn?.addEventListener('click', resetTransform);
closeBtn?.addEventListener('click', closeLightbox);

dialog.addEventListener('click', (event) => {
if (event.target === dialog) closeLightbox();
});

document.addEventListener('keydown', (event) => {
if (event.key === 'Escape' && dialog.open) closeLightbox();
});

dialog.addEventListener('close', () => {
img.src = '';
resetTransform();
});
})();
</script>

<script is:inline>
(() => {
const root = document.querySelector('[data-doc-search-root]');
if (!(root instanceof HTMLElement)) return;
const input = root.querySelector('[data-doc-search-input]');
const results = root.querySelector('[data-doc-search-results]');
if (!(input instanceof HTMLInputElement) || !(results instanceof HTMLDivElement)) return;

let tid = 0;
const hide = () => { results.hidden = true; results.replaceChildren(); };
const render = (items) => {
results.replaceChildren();
results.hidden = false;
if (!Array.isArray(items) || items.length === 0) {
const p = document.createElement('p');
p.className = 'docs-search-empty';
p.textContent = 'No results.';
results.appendChild(p);
return;
}
for (const item of items) {
if (!item || typeof item.href !== 'string') continue;
const a = document.createElement('a');
a.className = 'docs-search-result';
a.href = item.href;
const t = document.createElement('strong');
t.textContent = typeof item.title === 'string' ? item.title : 'Untitled';
const m = document.createElement('span');
m.textContent = typeof item.caseTitle === 'string' ? item.caseTitle : '';
a.appendChild(t);
a.appendChild(m);
results.appendChild(a);
}
};

input.addEventListener('input', () => {
const q = input.value.trim();
window.clearTimeout(tid);
if (q.length < 2) { hide(); return; }
tid = window.setTimeout(async () => {
try {
const res = await fetch('/api/docs/search?q=' + encodeURIComponent(q) + '&limit=8', {
headers: { accept: 'application/json' },
});
if (!res.ok) { hide(); return; }
render((await res.json()).items);
} catch { hide(); }
}, 180);
});

document.addEventListener('click', (e) => {
if (!(e.target instanceof Node) || !root.contains(e.target)) hide();
});
})();
</script>

<style>
:global(.site-main.docs-pg) {
padding: 0;
max-width: none;
}

.docs-shell {
display: grid;
grid-template-columns: minmax(15rem, 18rem) minmax(0, 1fr) minmax(12rem, 15rem);
gap: clamp(1rem, 2vw, 1.5rem);
width: min(100% - 2rem, 96rem);
margin-inline: auto;
padding: clamp(1rem, 2vw, 1.75rem) 0 clamp(2.5rem, 4vw, 4rem);
min-height: calc(100vh - 4rem);
background:
radial-gradient(circle at 8% 0%, color-mix(in srgb, var(--color-accent) 12%, transparent), transparent 28%),
radial-gradient(circle at 92% 8%, color-mix(in srgb, var(--color-focus) 9%, transparent), transparent 30%);
}

/* LEFT SIDEBAR */
.docs-sidebar {
position: sticky;
top: 1rem;
height: calc(100vh - 2rem);
overflow-y: auto;
scrollbar-width: thin;
scrollbar-color: var(--color-border) transparent;
align-self: start;
}
.docs-sidebar__inner {
padding: 1rem;
}
.docs-back-link {
display: inline-flex;
align-items: center;
gap: 0.3rem;
font-size: 0.8rem;
color: var(--color-text-muted);
text-decoration: none;
margin-bottom: 1.4rem;
transition: color 0.12s;
}
.docs-back-link:hover { color: var(--color-accent); }
.docs-sidebar__section { margin-bottom: 0.85rem; }
.docs-sidebar__eyebrow {
margin: 0 0 0.15rem;
font-size: 0.68rem;
text-transform: uppercase;
letter-spacing: 0;
color: var(--color-text-muted);
}
.docs-sidebar__title {
display: block;
font-size: 0.925rem;
line-height: 1.35;
color: var(--color-text);
}

/* Search */
.docs-search { position: relative; margin-bottom: 1.1rem; }
.docs-search input {
width: 100%;
padding: 0.58rem 0.7rem;
font-size: 0.84rem;
border-radius: var(--radius-sm);
border: 1px solid var(--color-border);
background: color-mix(in srgb, var(--color-bg-elevated) 82%, var(--color-surface));
color: var(--color-text);
outline: none;
transition: border-color var(--motion-fast) var(--ease-standard), box-shadow var(--motion-fast) var(--ease-standard), background-color var(--motion-fast) var(--ease-standard);
}
.docs-search input:focus {
border-color: var(--color-accent);
box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 16%, transparent);
}
.docs-search-results {
position: absolute;
top: calc(100% + 4px);
left: 0; right: 0;
z-index: 40;
padding: 0.3rem;
border: 1px solid var(--color-border);
border-radius: var(--radius-sm);
background: var(--color-bg-elevated);
box-shadow: var(--shadow-md);
display: grid;
gap: 0.12rem;
}
.docs-search-result {
display: grid;
gap: 0.1rem;
padding: 0.38rem 0.42rem;
border-radius: var(--radius-sm);
text-decoration: none;
font-size: 0.84rem;
transition: background 0.1s;
}
.docs-search-result:hover { background: var(--color-surface); }
.docs-search-result strong { color: var(--color-text); font-weight: 500; }
.docs-search-result span { font-size: 0.76rem; color: var(--color-text-muted); }
.docs-search-empty {
margin: 0;
padding: 0.35rem 0.42rem;
font-size: 0.84rem;
color: var(--color-text-muted);
}

/* Nav tree — :global because DocNavTree renders its own elements */
:global(.docs-nav-tree),
:global(.docs-nav-tree .nav-sub) {
list-style: none;
padding: 0;
margin: 0;
}
:global(.docs-nav-tree .nav-sub) {
margin: 0.1rem 0 0.25rem 0.65rem;
padding-left: 0.65rem;
border-left: 1px solid var(--color-border);
}
:global(.docs-nav-tree li) { display: grid; }
:global(.docs-nav-tree a) {
display: block;
padding: 0.38rem 0.55rem;
border-radius: var(--radius-sm);
font-size: 0.875rem;
line-height: 1.45;
text-decoration: none;
color: var(--color-text-muted);
transition: color var(--motion-fast) var(--ease-standard), background var(--motion-fast) var(--ease-standard), transform var(--motion-fast) var(--ease-standard);
}
:global(.docs-nav-tree a:hover) {
color: var(--color-text);
background: color-mix(in srgb, var(--color-border) 55%, transparent);
transform: translateX(2px);
}
:global(.docs-nav-tree a[aria-current='page']) {
color: var(--color-accent);
background: color-mix(in srgb, var(--color-accent) 11%, transparent);
font-weight: 600;
}
:global(.docs-nav-tree li.is-ancestor > a) { color: var(--color-text); }

/* CONTENT */
.docs-body { min-width: 0; overflow: hidden; }
.docs-article {
margin: 0 auto;
padding: clamp(1.1rem, 2.5vw, 2rem);
max-width: 72ch;
min-width: 0;
box-shadow: var(--shadow-md);
}

/* Breadcrumbs */
.docs-breadcrumbs ol {
list-style: none;
padding: 0;
margin: 0 0 1.1rem;
display: flex;
flex-wrap: wrap;
font-size: 0.8rem;
color: var(--color-text-muted);
}
.docs-breadcrumbs li { display: inline-flex; align-items: center; }
.docs-breadcrumbs li:not(:last-child)::after { content: '/'; margin: 0 0.35rem; opacity: 0.4; }
.docs-breadcrumbs a { color: var(--color-text-muted); text-decoration: none; transition: color 0.12s; }
.docs-breadcrumbs a:hover { color: var(--color-accent); }
.docs-breadcrumbs span[aria-current='page'] { color: var(--color-text-muted); }

.docs-hero {
position: relative;
margin-bottom: clamp(1.5rem, 3vw, 2.25rem);
padding: clamp(1.15rem, 2.2vw, 1.8rem);
border: 1px solid color-mix(in srgb, var(--color-accent) 20%, var(--color-border));
border-radius: var(--radius-md);
background:
linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 12%, transparent), transparent 44%),
color-mix(in srgb, var(--color-bg-elevated) 86%, var(--color-surface));
overflow: hidden;
}

.docs-hero::after {
content: "";
position: absolute;
inset-block-start: -4rem;
inset-inline-end: -3rem;
width: 12rem;
