---
import MainLayout from "../../layouts/MainLayout.astro";
import DocNavTree from "../../components/DocNavTree.astro";
import type { NavNode } from "../../components/DocNavTree.astro";
import { marked } from "marked";
import { env } from "cloudflare:workers";

export const prerender = false;

const slugParam = Astro.params.slug || "";
const parts = slugParam.split("/").filter(Boolean);

if (parts.length < 2 || parts[0] !== "case-studies") {
return new Response("Not found", { status: 404 });
}

const caseSlug = parts[1];
const sectionPath = parts.slice(2).join("/");
const targetSlugPath = sectionPath ? `${caseSlug}/${sectionPath}` : caseSlug;

const db = env.DB as D1Database | undefined;
if (!db) {
return new Response("D1 binding 'DB' is missing on this environment.", { status: 500 });
}

type CaseStudyRow = {
id: string;
title: string;
slug: string;
summary: string | null;
};

type DocumentRow = {
id: string;
title: string;
slug_path: string;
parent_id: string | null;
nav_order: number;
depth: number;
is_root: number;
body_md: string;
excerpt: string | null;
};

const caseStudy = await db
.prepare(`SELECT id, title, slug, summary FROM case_studies WHERE slug = ?1 LIMIT 1`)
.bind(caseSlug)
.first<CaseStudyRow>();

if (!caseStudy) return new Response("Not found", { status: 404 });

const docsResult = await db
.prepare(
`SELECT id, title, slug_path, parent_id, nav_order, depth, is_root, body_md, excerpt
 FROM documents
 WHERE case_study_id = ?1
 ORDER BY depth ASC, nav_order ASC, title ASC`
)
.bind(caseStudy.id)
.all<DocumentRow>();

const docs = docsResult.results || [];
const currentDoc = docs.find((d) => d.slug_path === targetSlugPath);
if (!currentDoc) return new Response("Not found", { status: 404 });

const toLink = (slugPath: string) => {
if (slugPath === caseSlug) return `/docs/case-studies/${caseSlug}/`;
const rel = slugPath.slice(caseSlug.length + 1);
return `/docs/case-studies/${caseSlug}/${rel}/`;
};

const buildTree = (allDocs: DocumentRow[]): NavNode[] => {
const map = new Map<string, NavNode>();
for (const d of allDocs) {
map.set(d.id, { id: d.id, title: d.title, slug_path: d.slug_path, nav_order: d.nav_order, children: [] });
}
const roots: NavNode[] = [];
for (const d of allDocs) {
const node = map.get(d.id)!;
if (d.parent_id && map.has(d.parent_id)) {
map.get(d.parent_id)!.children.push(node);
} else {
roots.push(node);
}
}
const sort = (nodes: NavNode[]) => {
nodes.sort((a, b) => a.nav_order - b.nav_order || a.title.localeCompare(b.title));
nodes.forEach((n) => sort(n.children));
};
sort(roots);
return roots;
};

const navTree = buildTree(docs);

const sectionSegments =
currentDoc.slug_path === caseSlug
? []
: currentDoc.slug_path.slice(caseSlug.length + 1).split("/").filter(Boolean);

const breadcrumbs: { label: string; href: string }[] = [
{ label: "Docs", href: "/docs/" },
{ label: caseStudy.title, href: `/docs/case-studies/${caseSlug}/` },
];
for (let i = 0; i < sectionSegments.length; i++) {
const sp = `${caseSlug}/${sectionSegments.slice(0, i + 1).join("/")}`;
const doc = docs.find((d) => d.slug_path === sp);
if (doc) breadcrumbs.push({ label: doc.title, href: toLink(sp) });
}

const flatOrdered = [...docs].sort(
(a, b) => a.nav_order - b.nav_order || a.title.localeCompare(b.title)
);
const currentIdx = flatOrdered.findIndex((d) => d.slug_path === targetSlugPath);
const prevDoc = currentIdx > 0 ? flatOrdered[currentIdx - 1] : null;
const nextDoc = currentIdx < flatOrdered.length - 1 ? flatOrdered[currentIdx + 1] : null;

const bodyHtml = await marked.parse(currentDoc.body_md || "");
---

<MainLayout
title={`${currentDoc.title} | ${caseStudy.title}`}
description={currentDoc.excerpt || caseStudy.summary || "Case study documentation"}
type="article"
width="full"
mainClass="docs-pg"
>
<div class="docs-shell">

<aside class="docs-sidebar">
<div class="docs-sidebar__inner">
<a href="/docs/" class="docs-back-link">
<svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
<path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
All docs
</a>

<div class="docs-sidebar__section">
<p class="docs-sidebar__eyebrow">Case Study</p>
<strong class="docs-sidebar__title">{caseStudy.title}</strong>
</div>

<div class="docs-search" data-doc-search-root>
<label for="docs-search-input" class="sr-only">Search docs</label>
<input
id="docs-search-input"
type="search"
placeholder="Search docs&#8230;"
autocomplete="off"
data-doc-search-input
/>
<div class="docs-search-results" data-doc-search-results hidden></div>
</div>

<nav aria-label="Case study navigation">
<ul class="docs-nav-tree">
<DocNavTree nodes={navTree} currentSlugPath={targetSlugPath} toLink={toLink} />
</ul>
</nav>
</div>
</aside>

<div class="docs-body">
<article class="docs-article">

{breadcrumbs.length > 1 && (
<nav class="docs-breadcrumbs" aria-label="Breadcrumb">
<ol>
{breadcrumbs.map((crumb, i) => (
<li>
{i === breadcrumbs.length - 1 ? (
<span aria-current="page">{crumb.label}</span>
) : (
<a href={crumb.href}>{crumb.label}</a>
)}
</li>
))}
</ol>
</nav>
)}

<h1 class="docs-page-title">{currentDoc.title}</h1>

<div class="docs-prose" data-doc-content>
<Fragment set:html={bodyHtml} />
</div>

{(prevDoc || nextDoc) && (
<nav class="docs-pager" aria-label="Pagination">
{prevDoc ? (
<a href={toLink(prevDoc.slug_path)} class="docs-pager__item docs-pager__item--prev">
<span class="docs-pager__dir">&#8592; Previous</span>
<span class="docs-pager__label">{prevDoc.title}</span>
</a>
) : <span />}
{nextDoc ? (
<a href={toLink(nextDoc.slug_path)} class="docs-pager__item docs-pager__item--next">
<span class="docs-pager__dir">Next &#8594;</span>
<span class="docs-pager__label">{nextDoc.title}</span>
</a>
) : <span />}
</nav>
)}
</article>
</div>

<aside class="docs-toc" aria-label="On this page" data-doc-rail>
<p class="docs-toc__label">On this page</p>
<ul class="docs-toc__list" data-doc-toc-list></ul>
</aside>

</div>
</MainLayout>

<script is:inline>
(() => {
const content = document.querySelector('[data-doc-content]');
const tocList = document.querySelector('[data-doc-toc-list]');
const rail = document.querySelector('[data-doc-rail]');
if (
!(content instanceof HTMLElement) ||
!(tocList instanceof HTMLElement) ||
!(rail instanceof HTMLElement)
) return;

const slugCounts = new Map();
const slugify = (value) => {
const base = value.toLowerCase().trim()
.replace(/[^a-z0-9\s-]/g, '')
.replace(/\s+/g, '-')
.replace(/-+/g, '-') || 'section';
const seen = slugCounts.get(base) || 0;
slugCounts.set(base, seen + 1);
return seen === 0 ? base : `${base}-${seen}`;
};

const headings = Array.from(content.querySelectorAll('h2, h3'));
if (headings.length === 0) { rail.classList.add('is-empty'); return; }

const items = headings.map((heading) => {
if (!heading.id) heading.id = slugify(heading.textContent || 'section');
const li = document.createElement('li');
if (heading.tagName.toLowerCase() === 'h3') li.classList.add('is-sub');
const link = document.createElement('a');
link.href = '#' + heading.id;
link.textContent = (heading.textContent || '').trim();
li.appendChild(link);
tocList.appendChild(li);
return { heading, link };
});

if (!('IntersectionObserver' in window)) return;

const observer = new IntersectionObserver(
(entries) => {
const visible = entries
.filter((e) => e.isIntersecting)
.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
if (visible.length === 0) return;
const activeId = visible[0].target.id;
items.forEach(({ heading, link }) => {
if (heading.id === activeId) link.setAttribute('aria-current', 'true');
else link.removeAttribute('aria-current');
});
},
{ rootMargin: '-12% 0px -75% 0px', threshold: [0, 1] }
);

items.forEach(({ heading }) => observer.observe(heading));
})();
</script>

<script is:inline>
(() => {
const root = document.querySelector('[data-doc-search-root]');
if (!(root instanceof HTMLElement)) return;
const input = root.querySelector('[data-doc-search-input]');
const results = root.querySelector('[data-doc-search-results]');
if (!(input instanceof HTMLInputElement) || !(results instanceof HTMLDivElement)) return;

let tid = 0;
const hide = () => { results.hidden = true; results.replaceChildren(); };
const render = (items) => {
results.replaceChildren();
results.hidden = false;
if (!Array.isArray(items) || items.length === 0) {
const p = document.createElement('p');
p.className = 'docs-search-empty';
p.textContent = 'No results.';
results.appendChild(p);
return;
}
for (const item of items) {
if (!item || typeof item.href !== 'string') continue;
const a = document.createElement('a');
a.className = 'docs-search-result';
a.href = item.href;
const t = document.createElement('strong');
t.textContent = typeof item.title === 'string' ? item.title : 'Untitled';
const m = document.createElement('span');
m.textContent = typeof item.caseTitle === 'string' ? item.caseTitle : '';
a.appendChild(t);
a.appendChild(m);
results.appendChild(a);
}
};

input.addEventListener('input', () => {
const q = input.value.trim();
window.clearTimeout(tid);
if (q.length < 2) { hide(); return; }
tid = window.setTimeout(async () => {
try {
const res = await fetch('/api/docs/search?q=' + encodeURIComponent(q) + '&limit=8', {
headers: { accept: 'application/json' },
});
if (!res.ok) { hide(); return; }
render((await res.json()).items);
} catch { hide(); }
}, 180);
});

document.addEventListener('click', (e) => {
if (!(e.target instanceof Node) || !root.contains(e.target)) hide();
});
})();
</script>

<style>
:global(.site-main.docs-pg) {
padding: 0;
}

.docs-shell {
display: grid;
grid-template-columns: 280px 1fr 220px;
min-height: calc(100vh - 4rem);
border-top: 1px solid var(--color-border);
}

/* LEFT SIDEBAR */
.docs-sidebar {
position: sticky;
top: 0;
height: 100vh;
overflow-y: auto;
border-right: 1px solid var(--color-border);
scrollbar-width: thin;
scrollbar-color: var(--color-border) transparent;
}
.docs-sidebar__inner {
padding: 1.5rem 1rem 2rem;
}
.docs-back-link {
display: inline-flex;
align-items: center;
gap: 0.3rem;
font-size: 0.8rem;
color: var(--color-text-muted);
text-decoration: none;
margin-bottom: 1.4rem;
transition: color 0.12s;
}
.docs-back-link:hover { color: var(--color-accent); }
.docs-sidebar__section { margin-bottom: 1rem; }
.docs-sidebar__eyebrow {
margin: 0 0 0.15rem;
font-size: 0.68rem;
text-transform: uppercase;
letter-spacing: 0.1em;
color: var(--color-text-muted);
}
.docs-sidebar__title {
display: block;
font-size: 0.925rem;
line-height: 1.35;
color: var(--color-text);
}

/* Search */
.docs-search { position: relative; margin-bottom: 1.1rem; }
.docs-search input {
width: 100%;
padding: 0.42rem 0.6rem;
font-size: 0.84rem;
border-radius: 0.5rem;
border: 1px solid var(--color-border);
background: var(--color-surface);
color: var(--color-text);
outline: none;
transition: border-color 0.15s, box-shadow 0.15s;
}
.docs-search input:focus {
border-color: var(--color-accent);
box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent) 18%, transparent);
}
.docs-search-results {
position: absolute;
top: calc(100% + 4px);
left: 0; right: 0;
z-index: 40;
padding: 0.3rem;
border: 1px solid var(--color-border);
border-radius: 0.55rem;
background: var(--color-bg-elevated);
box-shadow: var(--shadow-md);
display: grid;
gap: 0.12rem;
}
.docs-search-result {
display: grid;
gap: 0.1rem;
padding: 0.38rem 0.42rem;
border-radius: 0.38rem;
text-decoration: none;
font-size: 0.84rem;
transition: background 0.1s;
}
.docs-search-result:hover { background: var(--color-surface); }
.docs-search-result strong { color: var(--color-text); font-weight: 500; }
.docs-search-result span { font-size: 0.76rem; color: var(--color-text-muted); }
.docs-search-empty {
margin: 0;
padding: 0.35rem 0.42rem;
font-size: 0.84rem;
color: var(--color-text-muted);
}

/* Nav tree — :global because DocNavTree renders its own elements */
:global(.docs-nav-tree),
:global(.docs-nav-tree .nav-sub) {
list-style: none;
padding: 0;
margin: 0;
}
:global(.docs-nav-tree .nav-sub) {
margin: 0.1rem 0 0.25rem 0.65rem;
padding-left: 0.65rem;
border-left: 1px solid var(--color-border);
}
:global(.docs-nav-tree li) { display: grid; }
:global(.docs-nav-tree a) {
display: block;
padding: 0.28rem 0.5rem;
border-radius: 0.38rem;
font-size: 0.875rem;
line-height: 1.45;
text-decoration: none;
color: var(--color-text-muted);
transition: color 0.12s, background 0.12s;
}
:global(.docs-nav-tree a:hover) {
color: var(--color-text);
background: color-mix(in srgb, var(--color-border) 55%, transparent);
}
:global(.docs-nav-tree a[aria-current='page']) {
color: var(--color-accent);
background: color-mix(in srgb, var(--color-accent) 11%, transparent);
font-weight: 600;
}
:global(.docs-nav-tree li.is-ancestor > a) { color: var(--color-text); }

/* CONTENT */
.docs-body { min-width: 0; overflow: hidden; }
.docs-article {
margin: 0 auto;
padding: 2.5rem 3rem 4rem;
max-width: 72ch;
}

/* Breadcrumbs */
.docs-breadcrumbs ol {
list-style: none;
padding: 0;
margin: 0 0 1.1rem;
display: flex;
flex-wrap: wrap;
font-size: 0.8rem;
color: var(--color-text-muted);
}
.docs-breadcrumbs li { display: inline-flex; align-items: center; }
.docs-breadcrumbs li:not(:last-child)::after { content: '/'; margin: 0 0.35rem; opacity: 0.4; }
.docs-breadcrumbs a { color: var(--color-text-muted); text-decoration: none; transition: color 0.12s; }
.docs-breadcrumbs a:hover { color: var(--color-accent); }
.docs-breadcrumbs span[aria-current='page'] { color: var(--color-text-muted); }

/* Page title */
.docs-page-title {
margin: 0 0 1.5rem;
font-size: clamp(1.75rem, 1.25rem + 1.5vw, 2.4rem);
line-height: 1.18;
letter-spacing: -0.03em;
padding-bottom: 0.8rem;
border-bottom: 1px solid var(--color-border);
}

/* Prose */
.docs-prose {
font-size: 0.975rem;
line-height: 1.75;
--docs-h1-size: clamp(1.35rem, 1.18rem + 0.65vw, 1.75rem);
--docs-h2-size: clamp(1.2rem, 1.08rem + 0.52vw, 1.5rem);
--docs-h3-size: clamp(1.05rem, 0.98rem + 0.32vw, 1.22rem);
--docs-h4-size: 0.9rem;
}
.docs-prose :global(* + *) { margin-top: 1rem; }
.docs-prose :global(h1),
.docs-prose :global(h2),
.docs-prose :global(h3),
.docs-prose :global(h4),
.docs-prose :global(h5),
.docs-prose :global(h6) {
scroll-margin-top: 5.5rem;
color: var(--color-text);
line-height: 1.3;
letter-spacing: -0.01em;
}
.docs-prose :global(h1) {
margin-top: 2rem;
font-size: var(--docs-h1-size);
padding-bottom: 0.35rem;
border-bottom: 1px solid var(--color-border);
}
.docs-prose :global(h2) {
margin-top: 2rem;
font-size: var(--docs-h2-size);
line-height: 1.28;
padding-bottom: 0.35rem;
border-bottom: 1px solid var(--color-border);
}
.docs-prose :global(h3) {
margin-top: 1.5rem;
font-size: var(--docs-h3-size);
line-height: 1.36;
}
.docs-prose :global(h4) {
font-size: var(--docs-h4-size);
font-weight: 700;
text-transform: uppercase;
letter-spacing: 0.05em;
color: var(--color-text-muted);
}
.docs-prose :global(h5) {
font-size: 0.84rem;
font-weight: 700;
text-transform: uppercase;
letter-spacing: 0.06em;
color: var(--color-text-muted);
}
.docs-prose :global(h6) {
font-size: 0.8rem;
font-weight: 700;
letter-spacing: 0.04em;
color: var(--color-text-muted);
}
.docs-prose :global(h1:first-child),
.docs-prose :global(h2:first-child),
.docs-prose :global(h3:first-child) {
margin-top: 0;
}
.docs-prose :global(p),
.docs-prose :global(li) { color: var(--color-text-muted); }
.docs-prose :global(ul),
.docs-prose :global(ol) { padding-left: 1.4rem; }
.docs-prose :global(li + li) { margin-top: 0.28rem; }
.docs-prose :global(a) { text-underline-offset: 0.15em; }
.docs-prose :global(code) {
font-size: 0.88em;
padding: 0.12rem 0.32rem;
border-radius: 0.32rem;
background: var(--color-surface);
border: 1px solid var(--color-border);
color: var(--color-text);
}
.docs-prose :global(pre) {
margin-top: 1rem;
padding: 1rem 1.1rem;
border-radius: 0.65rem;
border: 1px solid var(--color-border);
background: var(--color-surface);
overflow-x: auto;
}
.docs-prose :global(pre code) { padding: 0; border: none; background: none; font-size: 0.875em; }
.docs-prose :global(blockquote) {
margin: 1rem 0;
padding: 0.3rem 0 0.3rem 1rem;
border-left: 3px solid var(--color-accent);
font-style: italic;
}
.docs-prose :global(table) { width: 100%; border-collapse: collapse; font-size: 0.925rem; }
.docs-prose :global(th),
.docs-prose :global(td) { padding: 0.5rem 0.7rem; border: 1px solid var(--color-border); text-align: left; vertical-align: top; }
.docs-prose :global(th) { background: var(--color-surface); font-weight: 600; color: var(--color-text); }
.docs-prose :global(img) { border-radius: var(--radius-sm); max-width: 100%; }
.docs-prose :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: 2rem 0; }

/* Prev / Next */
.docs-pager {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 0.75rem;
margin-top: 3rem;
padding-top: 1.5rem;
border-top: 1px solid var(--color-border);
}
.docs-pager__item {
display: grid;
gap: 0.2rem;
padding: 0.75rem 1rem;
border: 1px solid var(--color-border);
border-radius: 0.6rem;
text-decoration: none;
transition: border-color 0.15s, background 0.15s;
}
.docs-pager__item:hover {
border-color: var(--color-accent);
background: color-mix(in srgb, var(--color-accent) 5%, transparent);
}
.docs-pager__item--next { text-align: right; }
.docs-pager__dir {
display: block;
font-size: 0.75rem;
text-transform: uppercase;
letter-spacing: 0.06em;
color: var(--color-text-muted);
}
.docs-pager__label {
display: block;
font-size: 0.95rem;
font-weight: 600;
color: var(--color-text);
line-height: 1.3;
}

/* RIGHT TOC */
.docs-toc {
position: sticky;
top: 0;
height: 100vh;
overflow-y: auto;
padding: 2.5rem 1rem 2rem;
border-left: 1px solid var(--color-border);
scrollbar-width: thin;
scrollbar-color: var(--color-border) transparent;
}
.docs-toc.is-empty { display: none; }
.docs-toc__label {
margin: 0 0 0.55rem;
font-size: 0.68rem;
text-transform: uppercase;
letter-spacing: 0.1em;
color: var(--color-text-muted);
}
.docs-toc__list {
list-style: none;
padding: 0; margin: 0;
display: grid;
gap: 0.1rem;
}
.docs-toc__list a {
display: block;
padding: 0.22rem 0.4rem;
border-radius: 0.35rem;
font-size: 0.81rem;
line-height: 1.45;
text-decoration: none;
color: var(--color-text-muted);
transition: color 0.12s, background 0.12s;
}
.docs-toc__list a:hover { color: var(--color-text); }
.docs-toc__list a[aria-current='true'] {
color: var(--color-accent);
background: color-mix(in srgb, var(--color-accent) 9%, transparent);
font-weight: 500;
}
.docs-toc__list li.is-sub { padding-left: 0.7rem; }

/* RESPONSIVE */
@media (max-width: 1200px) {
.docs-shell { grid-template-columns: 260px 1fr; }
.docs-toc { display: none; }
}
@media (max-width: 860px) {
.docs-shell { grid-template-columns: 1fr; }
.docs-sidebar {
position: relative;
height: auto;
border-right: none;
border-bottom: 1px solid var(--color-border);
}
.docs-sidebar__inner { padding: 1rem; }
.docs-article { padding: 1.5rem 1.25rem 2.5rem; }
}
@media (max-width: 520px) {
.docs-pager { grid-template-columns: 1fr; }
}
</style>
