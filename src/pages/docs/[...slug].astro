---
import MainLayout from "../../layouts/MainLayout.astro";
import { marked } from "marked";
import { env } from "cloudflare:workers";

export const prerender = false;

const slugParam = Astro.params.slug || "";
const parts = slugParam.split("/").filter(Boolean);

if (parts.length < 2 || parts[0] !== "case-studies") {
	return new Response("Not found", { status: 404 });
}

const caseSlug = parts[1];
const sectionPath = parts.slice(2).join("/");
const targetSlugPath = sectionPath ? `${caseSlug}/${sectionPath}` : caseSlug;

const db = env.DB as D1Database | undefined;

if (!db) {
	return new Response("D1 binding 'DB' is missing on this environment.", { status: 500 });
}

type CaseStudyRow = {
	id: string;
	title: string;
	slug: string;
	summary: string | null;
};

type DocumentRow = {
	id: string;
	title: string;
	slug_path: string;
	parent_id: string | null;
	nav_order: number;
	depth: number;
	is_root: number;
	body_md: string;
	excerpt: string | null;
};

const caseStudy = await db
	.prepare(
		`SELECT id, title, slug, summary
		 FROM case_studies
		 WHERE slug = ?1
		 LIMIT 1`
	)
	.bind(caseSlug)
	.first<CaseStudyRow>();

if (!caseStudy) {
	return new Response("Not found", { status: 404 });
}

const docsResult = await db
	.prepare(
		`SELECT id, title, slug_path, parent_id, nav_order, depth, is_root, body_md, excerpt
		 FROM documents
		 WHERE case_study_id = ?1
		 ORDER BY depth ASC, nav_order ASC, title ASC`
	)
	.bind(caseStudy.id)
	.all<DocumentRow>();

const docs = docsResult.results || [];
const currentDoc = docs.find((doc) => doc.slug_path === targetSlugPath);

if (!currentDoc) {
	return new Response("Not found", { status: 404 });
}

const toLink = (slugPath: string) => {
	if (slugPath === caseSlug) return `/docs/case-studies/${caseSlug}/`;
	const rel = slugPath.slice(caseSlug.length + 1);
	return `/docs/case-studies/${caseSlug}/${rel}/`;
};

const navDocs = docs.filter((doc) => doc.slug_path !== caseSlug);

const bodyHtml = await marked.parse(currentDoc.body_md || "");
---

<MainLayout
	title={`${currentDoc.title} | ${caseStudy.title}`}
	description={currentDoc.excerpt || caseStudy.summary || "Case study documentation"}
	width="wide"
>
	<script type="module" src="/scripts/starlight-mermaid.js"></script>
	<section class="docs-shell">
		<aside class="docs-nav">
			<p class="docs-nav__label">Case Study</p>
			<h1 class="docs-nav__title">{caseStudy.title}</h1>
			<nav aria-label="Case study navigation">
				<ul>
					<li>
						<a href={`/docs/case-studies/${caseSlug}/`} aria-current={currentDoc.slug_path === caseSlug ? "page" : undefined}>
							Overview
						</a>
					</li>
					{navDocs.map((doc) => (
						<li class={`depth-${doc.depth}`}>
							<a href={toLink(doc.slug_path)} aria-current={doc.slug_path === currentDoc.slug_path ? "page" : undefined}>
								{doc.title}
							</a>
						</li>
					))}
				</ul>
			</nav>
		</aside>
		<article class="docs-content">
			<header>
				<p class="docs-content__eyebrow">Case Study</p>
				<h2>{currentDoc.title}</h2>
			</header>
			<div class="docs-prose">
				<Fragment set:html={bodyHtml} />
			</div>
		</article>
	</section>
</MainLayout>

<style>
	.docs-shell {
		display: grid;
		grid-template-columns: minmax(16rem, 20rem) minmax(0, 1fr);
		gap: 1.25rem;
	}
	.docs-nav {
		position: sticky;
		top: 5rem;
		align-self: start;
		max-height: calc(100vh - 6rem);
		overflow: auto;
		padding: 1rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-bg-elevated);
	}
	.docs-nav__label {
		margin: 0 0 0.35rem;
		font-size: 0.74rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.docs-nav__title {
		margin: 0 0 0.8rem;
		font-size: 1.15rem;
	}
	.docs-nav ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.3rem;
	}
	.docs-nav a {
		display: block;
		padding: 0.35rem 0.45rem;
		border-radius: 0.45rem;
		text-decoration: none;
	}
	.docs-nav a[aria-current="page"] {
		background: color-mix(in srgb, var(--color-accent) 18%, transparent);
		color: var(--color-text);
		font-weight: 700;
	}
	.docs-nav .depth-2 a {
		padding-left: 1rem;
	}
	.docs-nav .depth-3 a {
		padding-left: 1.5rem;
	}
	.docs-content {
		padding: 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-bg-elevated);
	}

	.docs-content > header h2 {
		margin: 0.35rem 0 0.4rem;
		font-size: clamp(1.45rem, 1.18rem + 0.9vw, 1.9rem);
		line-height: 1.25;
	}

	.docs-content__eyebrow {
		margin: 0;
		font-size: 0.72rem;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.docs-prose {
		font-size: 0.985rem;
		line-height: 1.72;
	}

	.docs-prose :global(* + *) {
		margin-top: 1rem;
	}

	.docs-prose :global(h1),
	.docs-prose :global(h2),
	.docs-prose :global(h3),
	.docs-prose :global(h4) {
		scroll-margin-top: 5.75rem;
		color: var(--color-text);
	}

	.docs-prose :global(h1) {
		margin-top: 1.1rem;
		font-size: clamp(1.5rem, 1.2rem + 1vw, 2rem);
		line-height: 1.28;
	}

	.docs-prose :global(h2) {
		margin-top: 1.35rem;
		font-size: clamp(1.28rem, 1.12rem + 0.7vw, 1.62rem);
		line-height: 1.3;
	}

	.docs-prose :global(h3) {
		margin-top: 1.1rem;
		font-size: clamp(1.12rem, 1.04rem + 0.48vw, 1.34rem);
		line-height: 1.36;
	}

	.docs-prose :global(h4) {
		font-size: 1.02rem;
		line-height: 1.45;
	}

	.docs-prose :global(p),
	.docs-prose :global(li) {
		color: var(--color-text-muted);
	}

	.docs-prose :global(ul),
	.docs-prose :global(ol) {
		padding-left: 1.25rem;
	}

	.docs-prose :global(li + li) {
		margin-top: 0.32rem;
	}

	.docs-prose :global(a) {
		text-underline-offset: 0.15em;
	}

	.docs-prose :global(code) {
		font-size: 0.9em;
		padding: 0.13rem 0.34rem;
		border-radius: 0.35rem;
	}

	.docs-prose :global(pre) {
		margin-top: 1rem;
		padding: 0.92rem 1rem;
		border-radius: 0.75rem;
	}

	.docs-prose :global(blockquote) {
		margin: 1rem 0;
		padding: 0.2rem 0 0.2rem 0.9rem;
		border-left: 3px solid var(--color-accent);
	}

	.docs-prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin-top: 1rem;
		font-size: 0.95rem;
	}

	.docs-prose :global(th),
	.docs-prose :global(td) {
		padding: 0.52rem 0.62rem;
		border: 1px solid var(--color-border);
		text-align: left;
		vertical-align: top;
	}

	.docs-prose :global(figure) {
		margin: 1.15rem 0;
	}

	.docs-prose :global(figcaption) {
		margin-top: 0.5rem;
		color: var(--color-text-muted);
		font-size: 0.9rem;
	}

	.docs-prose :global(.mermaid) {
		overflow-x: auto;
		padding: 0.65rem;
		border: 1px solid var(--color-border);
		border-radius: 0.75rem;
		background: color-mix(in srgb, var(--color-surface) 70%, transparent);
	}
	@media (max-width: 900px) {
		.docs-shell {
			grid-template-columns: 1fr;
		}
		.docs-nav {
			position: static;
			max-height: none;
		}
		.docs-content {
			padding: 1rem;
		}
	}
</style>
