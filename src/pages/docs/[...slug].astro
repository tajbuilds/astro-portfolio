---
import MainLayout from "../../layouts/MainLayout.astro";
import { marked } from "marked";
import { env } from "cloudflare:workers";

export const prerender = false;

const slugParam = Astro.params.slug || "";
const parts = slugParam.split("/").filter(Boolean);

if (parts.length < 2 || parts[0] !== "case-studies") {
	return new Response("Not found", { status: 404 });
}

const caseSlug = parts[1];
const sectionPath = parts.slice(2).join("/");
const targetSlugPath = sectionPath ? `${caseSlug}/${sectionPath}` : caseSlug;

const db = env.DB as D1Database | undefined;

if (!db) {
	return new Response("D1 binding 'DB' is missing on this environment.", { status: 500 });
}

type CaseStudyRow = {
	id: string;
	title: string;
	slug: string;
	summary: string | null;
};

type DocumentRow = {
	id: string;
	title: string;
	slug_path: string;
	parent_id: string | null;
	nav_order: number;
	depth: number;
	is_root: number;
	body_md: string;
	excerpt: string | null;
};

const caseStudy = await db
	.prepare(
		`SELECT id, title, slug, summary
		 FROM case_studies
		 WHERE slug = ?1
		 LIMIT 1`
	)
	.bind(caseSlug)
	.first<CaseStudyRow>();

if (!caseStudy) {
	return new Response("Not found", { status: 404 });
}

const docsResult = await db
	.prepare(
		`SELECT id, title, slug_path, parent_id, nav_order, depth, is_root, body_md, excerpt
		 FROM documents
		 WHERE case_study_id = ?1
		 ORDER BY depth ASC, nav_order ASC, title ASC`
	)
	.bind(caseStudy.id)
	.all<DocumentRow>();

const docs = docsResult.results || [];
const currentDoc = docs.find((doc) => doc.slug_path === targetSlugPath);

if (!currentDoc) {
	return new Response("Not found", { status: 404 });
}

const toLink = (slugPath: string) => {
	if (slugPath === caseSlug) return `/docs/case-studies/${caseSlug}/`;
	const rel = slugPath.slice(caseSlug.length + 1);
	return `/docs/case-studies/${caseSlug}/${rel}/`;
};

const navDocs = docs.filter((doc) => doc.slug_path !== caseSlug);

const sectionSegments = currentDoc.slug_path === caseSlug
	? []
	: currentDoc.slug_path.slice(caseSlug.length + 1).split('/').filter(Boolean);

const breadcrumbs = [
	{ label: 'Docs', href: '/docs/' },
	{ label: caseStudy.title, href: `/docs/case-studies/${caseSlug}/` },
];

for (let i = 0; i < sectionSegments.length; i += 1) {
	const slugPath = `${caseSlug}/${sectionSegments.slice(0, i + 1).join('/')}`;
	const doc = docs.find((item) => item.slug_path === slugPath);
	if (!doc) continue;
	breadcrumbs.push({ label: doc.title, href: toLink(slugPath) });
}

const bodyHtml = await marked.parse(currentDoc.body_md || "");
---

<MainLayout
	title={`${currentDoc.title} | ${caseStudy.title}`}
	description={currentDoc.excerpt || caseStudy.summary || "Case study documentation"}
	width="wide"
>
	<section class="docs-shell">
		<aside class="docs-nav">
			<p class="docs-nav__label">Case Study</p>
			<h1 class="docs-nav__title">{caseStudy.title}</h1>
			<div class="docs-search" data-doc-search-root>
				<label for="docs-search-input" class="sr-only">Search docs</label>
				<input id="docs-search-input" type="search" placeholder="Search docs..." autocomplete="off" data-doc-search-input />
				<div class="docs-search-results" data-doc-search-results hidden></div>
			</div>
			<nav aria-label="Case study navigation">
				<ul>
					<li>
						<a href={`/docs/case-studies/${caseSlug}/`} aria-current={currentDoc.slug_path === caseSlug ? "page" : undefined}>
							Overview
						</a>
					</li>
					{navDocs.map((doc) => (
						<li class={`depth-${doc.depth}`}>
							<a href={toLink(doc.slug_path)} aria-current={doc.slug_path === currentDoc.slug_path ? "page" : undefined}>
								{doc.title}
							</a>
						</li>
					))}
				</ul>
			</nav>
		</aside>
		<article class="docs-content">
			<header>
				<nav class="docs-breadcrumbs" aria-label="Breadcrumb">
					<ol>
						{breadcrumbs.map((crumb, index) => (
							<li>
								{index === breadcrumbs.length - 1 ? (
									<span aria-current="page">{crumb.label}</span>
								) : (
									<a href={crumb.href}>{crumb.label}</a>
								)}
							</li>
						))}
					</ol>
				</nav>
				<p class="docs-content__eyebrow">Case Study</p>
				<h2>{currentDoc.title}</h2>
			</header>
			<div class="docs-prose" data-doc-content>
				<Fragment set:html={bodyHtml} />
			</div>
		</article>
		<aside class="docs-right-rail" aria-label="On this page" data-doc-rail>
			<p class="docs-right-rail__label">On this page</p>
			<ul class="docs-right-rail__list" data-doc-toc-list></ul>
		</aside>
	</section>
</MainLayout>

<script is:inline>
	(() => {
		const content = document.querySelector('[data-doc-content]');
		const tocList = document.querySelector('[data-doc-toc-list]');
		const rail = document.querySelector('[data-doc-rail]');
		if (!(content instanceof HTMLElement) || !(tocList instanceof HTMLElement) || !(rail instanceof HTMLElement)) return;

		const slugCounts = new Map();
		const slugify = (value) => {
			const base = value
				.toLowerCase()
				.trim()
				.replace(/[^a-z0-9\s-]/g, '')
				.replace(/\s+/g, '-')
				.replace(/-+/g, '-') || 'section';
			const seen = slugCounts.get(base) || 0;
			slugCounts.set(base, seen + 1);
			return seen === 0 ? base : `${base}-${seen}`;
		};

		const headings = Array.from(content.querySelectorAll('h2, h3'));
		if (headings.length === 0) {
			rail.classList.add('is-empty');
			return;
		}

		const items = headings.map((heading) => {
			if (!heading.id) heading.id = slugify(heading.textContent || 'section');
			const item = document.createElement('li');
			if (heading.tagName.toLowerCase() === 'h3') item.classList.add('is-sub');

			const link = document.createElement('a');
			link.href = `#${heading.id}`;
			link.textContent = (heading.textContent || '').trim();
			item.appendChild(link);
			tocList.appendChild(item);
			return { heading, link };
		});

		if (!('IntersectionObserver' in window)) return;

		const observer = new IntersectionObserver(
			(entries) => {
				const visible = entries
					.filter((entry) => entry.isIntersecting)
					.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

				if (visible.length === 0) return;
				const currentId = visible[0].target.id;
				items.forEach(({ heading, link }) => {
					if (heading.id === currentId) {
						link.setAttribute('aria-current', 'true');
					} else {
						link.removeAttribute('aria-current');
					}
				});
			},
			{
				rootMargin: '-22% 0px -70% 0px',
				threshold: [0, 1],
			}
		);

		items.forEach(({ heading }) => observer.observe(heading));
	})();

	(() => {
		const root = document.querySelector('[data-doc-search-root]');
		if (!(root instanceof HTMLElement)) return;

		const input = root.querySelector('[data-doc-search-input]');
		const results = root.querySelector('[data-doc-search-results]');
		if (!(input instanceof HTMLInputElement) || !(results instanceof HTMLDivElement)) return;

		let debounceId = 0;

		const hide = () => {
			results.hidden = true;
			results.replaceChildren();
		};

		const render = (items) => {
			results.replaceChildren();
			results.hidden = false;

			if (!Array.isArray(items) || items.length === 0) {
				const empty = document.createElement('p');
				empty.className = 'docs-search-results__empty';
				empty.textContent = 'No results.';
				results.appendChild(empty);
				return;
			}

			for (const item of items) {
				if (!item || typeof item.href !== 'string') continue;
				const link = document.createElement('a');
				link.className = 'docs-search-results__item';
				link.href = item.href;

				const title = document.createElement('strong');
				title.textContent = typeof item.title === 'string' ? item.title : 'Untitled';

				const meta = document.createElement('span');
				meta.textContent = typeof item.caseTitle === 'string' ? item.caseTitle : '';

				link.appendChild(title);
				link.appendChild(meta);
				results.appendChild(link);
			}
		};

		input.addEventListener('input', () => {
			const q = input.value.trim();
			window.clearTimeout(debounceId);

			if (q.length < 2) {
				hide();
				return;
			}

			debounceId = window.setTimeout(async () => {
				try {
					const response = await fetch(`/api/docs/search?q=${encodeURIComponent(q)}&limit=8`, {
						headers: { accept: 'application/json' },
					});
					if (!response.ok) {
						hide();
						return;
					}
					const payload = await response.json();
					render(payload.items);
				} catch {
					hide();
				}
			}, 180);
		});

		document.addEventListener('click', (event) => {
			if (!(event.target instanceof Node)) return;
			if (!root.contains(event.target)) hide();
		});
	})();
</script>

<style>
	.docs-shell {
		display: grid;
		grid-template-columns: minmax(16rem, 20rem) minmax(0, 1fr) minmax(12rem, 16rem);
		gap: 1.25rem;
	}
	.docs-nav {
		position: sticky;
		top: 5rem;
		align-self: start;
		max-height: calc(100vh - 6rem);
		overflow: auto;
		padding: 1rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-bg-elevated);
	}
	.docs-nav__label {
		margin: 0 0 0.35rem;
		font-size: 0.74rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.docs-nav__title {
		margin: 0 0 0.8rem;
		font-size: 1.15rem;
	}
	.docs-search {
		position: relative;
		margin-bottom: 0.8rem;
	}
	.docs-search input {
		width: 100%;
		padding: 0.58rem 0.62rem;
		border-radius: 0.58rem;
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		color: var(--color-text);
	}
	.docs-search-results {
		position: absolute;
		top: calc(100% + 0.3rem);
		left: 0;
		right: 0;
		z-index: 25;
		display: grid;
		gap: 0.22rem;
		padding: 0.35rem;
		border: 1px solid var(--color-border);
		border-radius: 0.6rem;
		background: var(--color-bg-elevated);
		box-shadow: var(--shadow-md);
	}
	.docs-search-results__item {
		display: grid;
		gap: 0.1rem;
		padding: 0.4rem 0.45rem;
		border-radius: 0.46rem;
		text-decoration: none;
	}
	.docs-search-results__item span {
		font-size: 0.81rem;
		color: var(--color-text-muted);
	}
	.docs-search-results__empty {
		margin: 0;
		padding: 0.36rem 0.4rem;
		font-size: 0.9rem;
		color: var(--color-text-muted);
	}
	.docs-nav ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.3rem;
	}
	.docs-nav a {
		display: block;
		padding: 0.35rem 0.45rem;
		border-radius: 0.45rem;
		text-decoration: none;
	}
	.docs-nav a[aria-current="page"] {
		background: color-mix(in srgb, var(--color-accent) 18%, transparent);
		color: var(--color-text);
		font-weight: 700;
	}
	.docs-nav .depth-2 a {
		padding-left: 1rem;
	}
	.docs-nav .depth-3 a {
		padding-left: 1.5rem;
	}
	.docs-content {
		padding: 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-bg-elevated);
	}
	.docs-breadcrumbs {
		margin-bottom: 0.55rem;
	}
	.docs-breadcrumbs ol {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		font-size: 0.84rem;
	}
	.docs-breadcrumbs li {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}
	.docs-breadcrumbs li:not(:last-child)::after {
		content: '/';
		color: var(--color-text-muted);
	}
	.docs-breadcrumbs span[aria-current='page'] {
		color: var(--color-text-muted);
	}

	.docs-content > header h2 {
		margin: 0.35rem 0 0.4rem;
		font-size: clamp(1.45rem, 1.18rem + 0.9vw, 1.9rem);
		line-height: 1.25;
	}

	.docs-content__eyebrow {
		margin: 0;
		font-size: 0.72rem;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.docs-prose {
		font-size: 0.985rem;
		line-height: 1.72;
	}

	.docs-prose :global(* + *) {
		margin-top: 1rem;
	}

	.docs-prose :global(h1),
	.docs-prose :global(h2),
	.docs-prose :global(h3),
	.docs-prose :global(h4) {
		scroll-margin-top: 5.75rem;
		color: var(--color-text);
	}

	.docs-prose :global(h1) {
		margin-top: 1.1rem;
		font-size: clamp(1.5rem, 1.2rem + 1vw, 2rem);
		line-height: 1.28;
	}

	.docs-prose :global(h2) {
		margin-top: 1.35rem;
		font-size: clamp(1.28rem, 1.12rem + 0.7vw, 1.62rem);
		line-height: 1.3;
	}

	.docs-prose :global(h3) {
		margin-top: 1.1rem;
		font-size: clamp(1.12rem, 1.04rem + 0.48vw, 1.34rem);
		line-height: 1.36;
	}

	.docs-prose :global(h4) {
		font-size: 1.02rem;
		line-height: 1.45;
	}

	.docs-prose :global(p),
	.docs-prose :global(li) {
		color: var(--color-text-muted);
	}

	.docs-prose :global(ul),
	.docs-prose :global(ol) {
		padding-left: 1.25rem;
	}

	.docs-prose :global(li + li) {
		margin-top: 0.32rem;
	}

	.docs-prose :global(a) {
		text-underline-offset: 0.15em;
	}

	.docs-prose :global(code) {
		font-size: 0.9em;
		padding: 0.13rem 0.34rem;
		border-radius: 0.35rem;
	}

	.docs-prose :global(pre) {
		margin-top: 1rem;
		padding: 0.92rem 1rem;
		border-radius: 0.75rem;
	}

	.docs-prose :global(blockquote) {
		margin: 1rem 0;
		padding: 0.2rem 0 0.2rem 0.9rem;
		border-left: 3px solid var(--color-accent);
	}

	.docs-prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin-top: 1rem;
		font-size: 0.95rem;
	}

	.docs-prose :global(th),
	.docs-prose :global(td) {
		padding: 0.52rem 0.62rem;
		border: 1px solid var(--color-border);
		text-align: left;
		vertical-align: top;
	}

	.docs-prose :global(figure) {
		margin: 1.15rem 0;
	}

	.docs-prose :global(figcaption) {
		margin-top: 0.5rem;
		color: var(--color-text-muted);
		font-size: 0.9rem;
	}
	.docs-right-rail {
		position: sticky;
		top: 5rem;
		align-self: start;
		max-height: calc(100vh - 6rem);
		overflow: auto;
		padding: 0.9rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-bg-elevated);
	}
	.docs-right-rail.is-empty {
		display: none;
	}
	.docs-right-rail__label {
		margin: 0 0 0.55rem;
		font-size: 0.73rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.docs-right-rail__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.28rem;
	}
	.docs-right-rail__list li.is-sub {
		padding-left: 0.62rem;
	}
	.docs-right-rail__list a {
		display: block;
		padding: 0.26rem 0.38rem;
		border-radius: 0.42rem;
		text-decoration: none;
		font-size: 0.88rem;
	}
	.docs-right-rail__list a[aria-current='true'] {
		background: color-mix(in srgb, var(--color-accent) 18%, transparent);
		color: var(--color-text);
		font-weight: 700;
	}

	@media (max-width: 1180px) {
		.docs-shell {
			grid-template-columns: minmax(15rem, 19rem) minmax(0, 1fr);
		}
		.docs-right-rail {
			display: none;
		}
	}

	@media (max-width: 900px) {
		.docs-shell {
			grid-template-columns: 1fr;
		}
		.docs-nav {
			position: static;
			max-height: none;
		}
		.docs-content {
			padding: 1rem;
		}
	}
</style>
