---
import MainLayout from "../../layouts/MainLayout.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

type CaseStudyIndexItem = {
	slug: string;
	title: string;
};

const db = env.DB as D1Database | undefined;
if (!db) {
    return new Response("D1 binding 'DB' is missing on this environment.", { status: 500 });
}

const caseStudiesResult = await db
    .prepare(
        `SELECT cs.slug AS slug,
                cs.title AS title
         FROM case_studies cs
         WHERE cs.is_visible = 1
         AND cs.source_collection_id = (
             SELECT oc.id
             FROM outline_collections oc
             WHERE oc.slug = 'case-studies'
               AND oc.is_visible = 1
             ORDER BY oc.nav_order ASC, oc.updated_at DESC
             LIMIT 1
         )
         ORDER BY cs.nav_order ASC, cs.title ASC`
    )
    .all<CaseStudyIndexItem>();

const caseStudies = caseStudiesResult.results || [];
---

<MainLayout
    title="Docs Index | Tajinder Singh"
    description="Book-style chapter index for case-study documentation backed by D1."
    width="full"
    mainClass="docs-index-page"
>
    <section class="docs-index-shell" aria-labelledby="docs-index-title" data-docs-index>
        <div class="docs-index-book">
            <header class="docs-index-head">
                <p class="docs-index-kicker">Documentation</p>
                <h1 id="docs-index-title">Case Study Chapters</h1>
                <p class="docs-index-subtitle">
                    Book-style index of chapter titles. Choose a case study to open its full documentation.
                </p>
                <label class="docs-index-search-label" for="docs-index-search">Find chapter</label>
                <input
                    id="docs-index-search"
                    class="docs-index-search"
                    type="search"
                    placeholder="Search case studies..."
                    autocomplete="off"
                    data-docs-index-search
                />
            </header>

            <div class="docs-index-viewport" data-docs-index-viewport>
                <ol class="docs-index-list" data-docs-index-list>
                    {caseStudies.map((item, index) => (
                        <li data-title={item.title.toLowerCase()}>
                            <a href={`/docs/case-studies/${item.slug}/`}>
                                <span class="docs-index-serial">{String(index + 1).padStart(2, "0")}</span>
                                <span class="docs-index-title">{item.title}</span>
                            </a>
                        </li>
                    ))}
                </ol>
                <p class="docs-index-empty" data-docs-index-empty hidden>No matching case study.</p>
            </div>
        </div>
    </section>
</MainLayout>

<script is:inline>
    (() => {
        const root = document.querySelector('[data-docs-index]');
        if (!(root instanceof HTMLElement)) return;

        const search = root.querySelector('[data-docs-index-search]');
        const list = root.querySelector('[data-docs-index-list]');
        const empty = root.querySelector('[data-docs-index-empty]');
        if (!(search instanceof HTMLInputElement) || !(list instanceof HTMLOListElement) || !(empty instanceof HTMLParagraphElement)) return;

        const items = Array.from(list.querySelectorAll('li'));

        const filter = () => {
            const query = search.value.trim().toLowerCase();
            let visibleCount = 0;

            for (const item of items) {
                if (!(item instanceof HTMLLIElement)) continue;
                const title = item.dataset.title || '';
                const show = query.length === 0 || title.includes(query);
                item.hidden = !show;
                if (show) visibleCount += 1;
            }

            empty.hidden = visibleCount !== 0;
            list.hidden = visibleCount === 0;
        };

        search.addEventListener('input', filter);
    })();
</script>

<style>
    :global(.site-main.docs-index-page) {
        padding: 0;
    }

    .docs-index-shell {
        min-height: calc(100vh - 4rem);
        padding: clamp(1rem, 2vw, 2.2rem);
        display: grid;
        align-items: center;
        background: radial-gradient(circle at 10% -15%, color-mix(in srgb, var(--color-accent) 16%, transparent), transparent 45%);
    }

    .docs-index-book {
        width: min(100%, 78rem);
        margin-inline: auto;
        border: 1px solid var(--color-border);
        border-radius: 1rem;
        background: color-mix(in srgb, var(--color-bg-elevated) 90%, var(--color-surface));
        box-shadow: var(--shadow-md);
        overflow: hidden;
    }

    .docs-index-head {
        padding: clamp(1rem, 2vw, 1.6rem);
        border-bottom: 1px solid var(--color-border);
        display: grid;
        gap: 0.45rem;
    }

    .docs-index-kicker {
        margin: 0;
        color: var(--color-text-muted);
        font-size: 0.72rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .docs-index-head h1 {
        margin: 0;
        font-size: clamp(1.2rem, 1rem + 1.3vw, 1.95rem);
        line-height: 1.2;
    }

    .docs-index-subtitle {
        margin: 0;
        color: var(--color-text-muted);
        font-size: 0.95rem;
        max-width: 70ch;
    }

    .docs-index-search-label {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--color-text-muted);
        margin-top: 0.15rem;
    }

    .docs-index-search {
        width: min(100%, 28rem);
        border-radius: 0.62rem;
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        color: var(--color-text);
        padding: 0.56rem 0.7rem;
        font: inherit;
    }

    .docs-index-search:focus-visible {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 15%, transparent);
    }

    .docs-index-viewport {
        max-height: min(68vh, 44rem);
        overflow-y: auto;
        scrollbar-gutter: stable;
        padding: 0.8rem;
    }

    .docs-index-list {
        margin: 0;
        padding: 0;
        list-style: none;
        counter-reset: chapter;
        display: grid;
        gap: 0.24rem;
    }

    .docs-index-list li a {
        display: grid;
        grid-template-columns: auto 1fr;
        align-items: center;
        gap: 0.8rem;
        padding: 0.56rem 0.62rem;
        border-radius: 0.6rem;
        text-decoration: none;
        color: var(--color-text);
        border: 1px solid transparent;
        transition: background-color 120ms ease, border-color 120ms ease;
    }

    .docs-index-list li a:hover,
    .docs-index-list li a:focus-visible {
        outline: none;
        background: color-mix(in srgb, var(--color-accent) 11%, transparent);
        border-color: color-mix(in srgb, var(--color-accent) 42%, var(--color-border));
    }

    .docs-index-serial {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.82rem;
        color: var(--color-text-muted);
        letter-spacing: 0.04em;
        min-width: 2.2rem;
    }

    .docs-index-title {
        font-size: 0.98rem;
        line-height: 1.35;
    }

    .docs-index-empty {
        margin: 0.35rem;
        padding: 0.75rem;
        border: 1px dashed var(--color-border);
        border-radius: 0.62rem;
        color: var(--color-text-muted);
        text-align: center;
    }

    @media (max-width: 700px) {
        .docs-index-shell {
            min-height: auto;
            padding: 0.8rem;
        }

        .docs-index-head {
            padding: 0.9rem;
        }

        .docs-index-viewport {
            max-height: 70vh;
            padding: 0.65rem;
        }

        .docs-index-list li a {
            gap: 0.55rem;
            padding: 0.5rem 0.52rem;
        }
    }
</style>
