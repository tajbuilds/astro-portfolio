---
import MainLayout from "../../layouts/MainLayout.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

type CaseStudyCard = {
slug: string;
title: string;
summary: string | null;
docs_total: number;
};

type RecentDoc = {
case_slug: string;
case_title: string;
doc_title: string;
slug_path: string;
excerpt: string | null;
};

const db = env.DB as D1Database | undefined;
if (!db) {
return new Response("D1 binding 'DB' is missing on this environment.", { status: 500 });
}

const caseStudiesResult = await db
.prepare(
`SELECT cs.slug AS slug,
        cs.title AS title,
        cs.summary AS summary,
        COUNT(d.id) AS docs_total
 FROM case_studies cs
 LEFT JOIN documents d ON d.case_study_id = cs.id
 WHERE cs.is_visible = 1
 GROUP BY cs.id, cs.slug, cs.title, cs.summary, cs.nav_order
 ORDER BY cs.nav_order ASC, cs.title ASC`
)
.all<CaseStudyCard>();

const recentDocsResult = await db
.prepare(
`SELECT cs.slug AS case_slug,
        cs.title AS case_title,
        d.title AS doc_title,
        d.slug_path AS slug_path,
        d.excerpt AS excerpt
 FROM documents d
 JOIN case_studies cs ON cs.id = d.case_study_id
 WHERE cs.is_visible = 1
 ORDER BY cs.nav_order ASC, d.nav_order ASC, d.title ASC
 LIMIT 18`
)
.all<RecentDoc>();

const caseStudies = caseStudiesResult.results || [];
const recentDocs = recentDocsResult.results || [];

const toDocHref = (caseSlug: string, slugPath: string) => {
if (slugPath === caseSlug) return `/docs/case-studies/${caseSlug}/`;
const rel = slugPath.startsWith(`${caseSlug}/`) ? slugPath.slice(caseSlug.length + 1) : "";
return rel ? `/docs/case-studies/${caseSlug}/${rel}/` : `/docs/case-studies/${caseSlug}/`;
};
---

<MainLayout
title="Docs | Tajinder Singh"
description="Architecture documentation and deep technical case-study sections backed by D1."
width="full"
mainClass="docs-pg"
>
<div class="docs-shell">
<aside class="docs-sidebar">
<div class="docs-sidebar__inner">
<p class="docs-sidebar__eyebrow">Knowledge Base</p>
<h1 class="docs-sidebar__title">Architecture Docs</h1>
<p class="docs-sidebar__copy">
Detailed technical docs synced from Outline and served from D1.
</p>

<form class="docs-search" action="/docs/" data-docs-home-search>
<label for="docs-home-search-input" class="sr-only">Search docs</label>
<input
id="docs-home-search-input"
type="search"
name="q"
placeholder="Search docs..."
autocomplete="off"
/>
<div class="docs-search-results" data-docs-home-search-results hidden></div>
</form>

<nav aria-label="Case studies">
<p class="docs-sidebar__group-label">Case Studies</p>
<ul class="docs-case-list">
{caseStudies.map((item) => (
<li>
<a href={`/docs/case-studies/${item.slug}/`}>
<span>{item.title}</span>
<small>{item.docs_total}</small>
</a>
</li>
))}
</ul>
</nav>
</div>
</aside>

<div class="docs-body">
<article class="docs-article">
<nav class="docs-breadcrumbs" aria-label="Breadcrumb">
<ol>
<li><span aria-current="page">Docs</span></li>
</ol>
</nav>

<h2 class="docs-page-title">Documentation Home</h2>
<p class="docs-lede">
Use this hub to navigate technical case-study docs with deep architecture sections,
decision logs, and implementation details.
</p>

<section class="docs-section" aria-labelledby="docs-cases-title">
<h3 id="docs-cases-title">Case Study Index</h3>
<ul class="docs-case-grid">
{caseStudies.map((item) => (
<li>
<a href={`/docs/case-studies/${item.slug}/`} class="docs-case-card">
<strong>{item.title}</strong>
<span>{item.summary || "Explore implementation details and architecture decisions."}</span>
<em>{item.docs_total} section{item.docs_total === 1 ? "" : "s"}</em>
</a>
</li>
))}
</ul>
</section>

<section class="docs-section" aria-labelledby="docs-recent-title">
<h3 id="docs-recent-title">Recent Sections</h3>
<ul class="docs-recent-list">
{recentDocs.map((doc) => (
<li>
<a href={toDocHref(doc.case_slug, doc.slug_path)}>{doc.doc_title}</a>
<span>{doc.case_title}</span>
</li>
))}
</ul>
</section>
</article>
</div>

<aside class="docs-rail" aria-label="Quick links">
<p class="docs-rail__label">Quick Links</p>
<ul class="docs-rail__list">
<li><a href="/work/">Portfolio Case Studies</a></li>
<li><a href="/about/">About</a></li>
<li><a href="/contact/">Contact</a></li>
</ul>

<p class="docs-rail__label">Jump to Case</p>
<ul class="docs-rail__list">
{caseStudies.slice(0, 8).map((item) => (
<li><a href={`/docs/case-studies/${item.slug}/`}>{item.title}</a></li>
))}
</ul>
</aside>
</div>
</MainLayout>

<script is:inline>
(() => {
const root = document.querySelector('[data-docs-home-search]');
if (!(root instanceof HTMLFormElement)) return;

const input = root.querySelector('input[type="search"]');
const resultBox = root.querySelector('[data-docs-home-search-results]');
if (!(input instanceof HTMLInputElement) || !(resultBox instanceof HTMLDivElement)) return;

let debounceId = 0;

const hideResults = () => {
resultBox.hidden = true;
resultBox.replaceChildren();
};

const renderItems = (items) => {
resultBox.replaceChildren();
resultBox.hidden = false;

if (!Array.isArray(items) || items.length === 0) {
const empty = document.createElement('p');
empty.className = 'docs-search-results__empty';
empty.textContent = 'No results.';
resultBox.appendChild(empty);
return;
}

for (const item of items) {
if (!item || typeof item.href !== 'string') continue;
const link = document.createElement('a');
link.className = 'docs-search-results__item';
link.href = item.href;

const title = document.createElement('strong');
title.textContent = typeof item.title === 'string' ? item.title : 'Untitled';

const meta = document.createElement('span');
meta.textContent = typeof item.caseTitle === 'string' ? item.caseTitle : '';

link.appendChild(title);
link.appendChild(meta);
resultBox.appendChild(link);
}
};

input.addEventListener('input', () => {
const q = input.value.trim();
window.clearTimeout(debounceId);

if (q.length < 2) {
hideResults();
return;
}

debounceId = window.setTimeout(async () => {
try {
const res = await fetch(`/api/docs/search?q=${encodeURIComponent(q)}&limit=8`, {
headers: { accept: 'application/json' },
});
if (!res.ok) {
hideResults();
return;
}
const payload = await res.json();
renderItems(payload.items);
} catch {
hideResults();
}
}, 180);
});

document.addEventListener('click', (event) => {
if (!(event.target instanceof Node)) return;
if (!root.contains(event.target)) hideResults();
});
})();
</script>

<style>
:global(.site-main.docs-pg) {
padding: 0;
}

.docs-shell {
display: grid;
grid-template-columns: 280px 1fr 220px;
min-height: calc(100vh - 4rem);
border-top: 1px solid var(--color-border);
}

.docs-sidebar {
position: sticky;
top: 0;
height: 100vh;
overflow-y: auto;
border-right: 1px solid var(--color-border);
}

.docs-sidebar__inner {
padding: 1.5rem 1rem 2rem;
}

.docs-sidebar__eyebrow {
margin: 0 0 0.2rem;
font-size: 0.68rem;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(--color-text-muted);
}

.docs-sidebar__title {
margin: 0;
font-size: 1.35rem;
line-height: 1.2;
}

.docs-sidebar__copy {
margin: 0.5rem 0 1rem;
font-size: 0.88rem;
color: var(--color-text-muted);
}

.docs-sidebar__group-label {
margin: 1.1rem 0 0.35rem;
font-size: 0.72rem;
letter-spacing: 0.08em;
text-transform: uppercase;
color: var(--color-text-muted);
}

.docs-search {
position: relative;
}

.docs-search input {
width: 100%;
padding: 0.5rem 0.6rem;
border-radius: 0.5rem;
border: 1px solid var(--color-border);
background: var(--color-surface);
color: var(--color-text);
}

.docs-search-results {
position: absolute;
top: calc(100% + 4px);
left: 0;
right: 0;
z-index: 40;
display: grid;
gap: 0.15rem;
padding: 0.3rem;
border: 1px solid var(--color-border);
border-radius: 0.55rem;
background: var(--color-bg-elevated);
box-shadow: var(--shadow-md);
}

.docs-search-results__item {
display: grid;
gap: 0.1rem;
padding: 0.38rem 0.42rem;
border-radius: 0.38rem;
text-decoration: none;
}

.docs-search-results__item span {
font-size: 0.76rem;
color: var(--color-text-muted);
}

.docs-search-results__empty {
margin: 0;
padding: 0.35rem 0.42rem;
font-size: 0.84rem;
color: var(--color-text-muted);
}

.docs-case-list {
list-style: none;
padding: 0;
margin: 0;
display: grid;
gap: 0.2rem;
}

.docs-case-list a {
display: flex;
justify-content: space-between;
gap: 0.6rem;
padding: 0.3rem 0.45rem;
border-radius: 0.38rem;
text-decoration: none;
color: var(--color-text-muted);
}

.docs-case-list a:hover {
background: var(--color-surface);
color: var(--color-text);
}

.docs-case-list small {
font-size: 0.74rem;
color: var(--color-text-muted);
}

.docs-body {
min-width: 0;
}

.docs-article {
margin: 0 auto;
padding: 2.5rem 3rem 4rem;
max-width: 74ch;
}

.docs-breadcrumbs ol {
list-style: none;
padding: 0;
margin: 0 0 1rem;
font-size: 0.8rem;
color: var(--color-text-muted);
}

.docs-page-title {
margin: 0;
font-size: clamp(1.65rem, 1.2rem + 1.3vw, 2.3rem);
line-height: 1.2;
}

.docs-lede {
margin-top: 0.7rem;
font-size: 1rem;
}

.docs-section {
margin-top: 2rem;
}

.docs-section > h3 {
margin: 0;
font-size: 1.2rem;
padding-bottom: 0.3rem;
border-bottom: 1px solid var(--color-border);
}

.docs-case-grid {
list-style: none;
padding: 0;
margin: 0.9rem 0 0;
display: grid;
grid-template-columns: repeat(2, minmax(0, 1fr));
gap: 0.7rem;
}

.docs-case-card {
display: grid;
gap: 0.35rem;
padding: 0.8rem;
text-decoration: none;
border: 1px solid var(--color-border);
border-radius: 0.62rem;
background: var(--color-bg-elevated);
}

.docs-case-card strong {
font-size: 0.98rem;
color: var(--color-text);
}

.docs-case-card span {
font-size: 0.88rem;
color: var(--color-text-muted);
}

.docs-case-card em {
font-style: normal;
font-size: 0.76rem;
letter-spacing: 0.04em;
text-transform: uppercase;
color: var(--color-text-muted);
}

.docs-recent-list {
list-style: none;
padding: 0;
margin: 0.9rem 0 0;
display: grid;
gap: 0.45rem;
}

.docs-recent-list li {
display: grid;
gap: 0.12rem;
}

.docs-recent-list span {
font-size: 0.82rem;
color: var(--color-text-muted);
}

.docs-rail {
position: sticky;
top: 0;
height: 100vh;
overflow-y: auto;
padding: 2.5rem 1rem 2rem;
border-left: 1px solid var(--color-border);
}

.docs-rail__label {
margin: 0 0 0.45rem;
font-size: 0.68rem;
text-transform: uppercase;
letter-spacing: 0.1em;
color: var(--color-text-muted);
}

.docs-rail__list {
list-style: none;
padding: 0;
margin: 0 0 1.15rem;
display: grid;
gap: 0.2rem;
}

.docs-rail__list a {
display: block;
padding: 0.22rem 0.34rem;
font-size: 0.84rem;
border-radius: 0.34rem;
text-decoration: none;
color: var(--color-text-muted);
}

.docs-rail__list a:hover {
color: var(--color-text);
background: var(--color-surface);
}

@media (max-width: 1200px) {
.docs-shell {
grid-template-columns: 260px 1fr;
}

.docs-rail {
display: none;
}
}

@media (max-width: 900px) {
.docs-shell {
grid-template-columns: 1fr;
}

.docs-sidebar {
position: relative;
height: auto;
border-right: none;
border-bottom: 1px solid var(--color-border);
}

.docs-sidebar__inner {
padding: 1rem;
}

.docs-article {
padding: 1.5rem 1.2rem 2.5rem;
}

.docs-case-grid {
grid-template-columns: 1fr;
}
}
</style>
