---
import MainLayout from '../../../layouts/MainLayout.astro';
import Container from '../../../components/Container.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import PillTag from '../../../components/PillTag.astro';
import {
	contentSlug,
	getPublishedWorkEntries,
	getPublishedWorkTags,
	slugifyTag,
} from '../../../lib/data/portfolio-data';

const allWork = await getPublishedWorkEntries();

export async function getStaticPaths() {
	const tags = await getPublishedWorkTags();
	return tags.map((tag) => ({
		params: { tag: slugifyTag(tag) },
		props: { tag },
	}));
}

const { tag } = Astro.props;
const tagSlug = slugifyTag(String(tag));
const filtered = allWork.filter((item) =>
	item.data.tags.some((entry) => slugifyTag(entry) === tagSlug),
);
---

<MainLayout
	title={`${tag} | Work | Tajinder Singh`}
	description={`Case studies tagged ${tag}.`}
	width="full"
>
	<Container size="wide">
		<SectionHeading
			eyebrow="Filtered"
			title={`Work tagged: ${tag}`}
			description="Focused case studies within this domain."
		/>
		<p class="tag-back"><PillTag label="<- Back to all work" href="/work/" /></p>
		<ul class="work-grid">
			{
				filtered.map((item) => (
					<li>
						<ProjectCard
							title={item.data.title}
							description={item.data.description}
							tags={item.data.tags}
							date={item.data.date}
							href={`/work/${contentSlug(item.id)}/`}
						/>
					</li>
				))
			}
		</ul>
	</Container>
</MainLayout>

<style>
	.tag-back {
		margin-bottom: 1.3rem;
	}

	.work-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	@media (max-width: 900px) {
		.work-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

