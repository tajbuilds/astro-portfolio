---
import { render } from 'astro:content';
import WorkCaseStudy from '../../layouts/WorkCaseStudy.astro';
import { contentSlug, type WorkEntry, getPublishedWorkEntries } from '../../lib/data/portfolio-data';

export async function getStaticPaths() {
	const sortedWork = await getPublishedWorkEntries();

	return sortedWork.map((post, index) => ({
		params: { slug: contentSlug(post.id) },
		props: {
			post,
			previous: sortedWork[index - 1]
				? { title: sortedWork[index - 1].data.title, slug: contentSlug(sortedWork[index - 1].id) }
				: null,
			next: sortedWork[index + 1]
				? { title: sortedWork[index + 1].data.title, slug: contentSlug(sortedWork[index + 1].id) }
				: null,
		},
	}));
}

interface Props {
	post: WorkEntry;
	previous: { title: string; slug: string } | null;
	next: { title: string; slug: string } | null;
}

const { post, previous, next } = Astro.props;
const { Content } = await render(post);
const words = post.body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(words / 220));
---

<WorkCaseStudy
	title={post.data.title}
	description={post.data.description}
	date={post.data.date}
	tags={post.data.tags}
	github={post.data.github}
	externalCaseStudyUrl={post.data.externalCaseStudyUrl}
	readingTime={readingTime}
	previous={previous ?? undefined}
	next={next ?? undefined}
>
	<Content />
</WorkCaseStudy>
