---
import { render } from 'astro:content';
import WorkCaseStudy from '../../layouts/WorkCaseStudy.astro';
import { contentSlug, getPublishedWorkEntries } from '../../lib/data/portfolio-data';

const slug = Astro.params.slug?.toLowerCase() ?? '';
const sortedWork = await getPublishedWorkEntries();
const index = sortedWork.findIndex((entry) => contentSlug(entry.id).toLowerCase() === slug);
const post = index >= 0 ? sortedWork[index] : null;

if (!post) {
	return Astro.redirect('/work/', 302);
}

const previous =
	sortedWork[index - 1]
		? { title: sortedWork[index - 1].data.title, slug: contentSlug(sortedWork[index - 1].id) }
		: undefined;

const next =
	sortedWork[index + 1]
		? { title: sortedWork[index + 1].data.title, slug: contentSlug(sortedWork[index + 1].id) }
		: undefined;

const { Content, headings } = await render(post);
const words = post.body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(words / 220));
---

<WorkCaseStudy
	title={post.data.title}
	description={post.data.description}
	date={post.data.date}
	tags={post.data.tags}
	github={post.data.github}
	externalCaseStudyUrl={post.data.externalCaseStudyUrl}
	headings={headings}
	readingTime={readingTime}
	previous={previous}
	next={next}
>
	<Content />
</WorkCaseStudy>
