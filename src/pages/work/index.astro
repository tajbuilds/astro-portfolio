---
import MainLayout from '../../layouts/MainLayout.astro';
import Container from '../../components/Container.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import PillTag from '../../components/PillTag.astro';
import {
	contentSlug,
	getPublishedWorkEntries,
	getPublishedWorkTags,
	slugifyTag,
} from '../../lib/data/portfolio-data';

const workItems = await getPublishedWorkEntries();
const tags = await getPublishedWorkTags();
---

<MainLayout
	title="Work | Tajinder Singh"
	description="Architecture case studies focused on edge security, automation, and data/search systems."
	width="full"
>
	<Container size="wide">
		<section class="work-intro">
			<div data-reveal="soft">
				<SectionHeading
					eyebrow="Portfolio"
					title="Case Studies"
					description="Selected architecture and platform work across verification pipelines, search systems, and high-leverage automation."
				/>
			</div>
		</section>

		<section class="work-filter" aria-label="Filter by tag" data-reveal="soft">
			<p>Filter by focus area:</p>
			<div class="work-filter__tags">
				<PillTag label="All" href="/work/" />
				{tags.map((tag) => <PillTag label={tag} href={`/work/tags/${slugifyTag(tag)}/`} />)}
			</div>
		</section>

		<section>
			<ul class="work-grid">
				{
					workItems.map((item) => (
						<li data-reveal="soft">
							<ProjectCard
								title={item.data.title}
								description={item.data.description}
								tags={item.data.tags}
								date={item.data.date}
								href={`/work/${contentSlug(item.id)}/`}
							/>
						</li>
					))
				}
			</ul>
		</section>
	</Container>
</MainLayout>

<style>
	.work-intro {
		margin-bottom: var(--space-5);
	}

	.work-filter {
		display: grid;
		gap: 0.7rem;
		margin-bottom: var(--space-6);
		padding: 0.95rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-bg-elevated) 90%, transparent);
		box-shadow: var(--shadow-sm);
	}

	.work-filter p {
		margin: 0;
		font-size: 0.84rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.work-filter__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.work-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.work-grid li {
		height: 100%;
	}

	@media (max-width: 900px) {
		.work-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

