---
import MainLayout from '../../layouts/MainLayout.astro';
import Container from '../../components/Container.astro';
import SectionHeading from '../../components/SectionHeading.astro';
---

<MainLayout title="Blog | Tajinder Singh" description="Notes and short technical write-ups.">
	<Container size="wide">
		<section class="blog-intro">
			<SectionHeading
				eyebrow="Blog"
				title="Technical Notes"
				description="Writing is intentionally secondary to case studies. Long-form notes and architecture observations are coming soon."
			/>
		</section>

		<p class="coming-soon-note" aria-live="polite">Blog posts are coming soon.</p>
	</Container>
</MainLayout>

<style>
	.coming-soon-note {
		margin: 0;
		max-width: 52rem;
		font-size: 0.98rem;
		color: var(--color-text-muted);
	}
</style>