---
interface ProofItem {
	label: string;
	copy: string;
}

interface Props {
	eyebrow?: string;
	title: string;
	items: ProofItem[];
	compact?: boolean;
}

const { eyebrow, title, items, compact = false } = Astro.props;
---

<section
	class:list={['proof-strip', 'surface-card', 'surface-card--feature', { 'proof-strip--compact': compact }]}
	data-reveal="soft"
>
	<div class="proof-strip__intro">
		{eyebrow && <p class="proof-strip__eyebrow">{eyebrow}</p>}
		<h2>{title}</h2>
	</div>
	<div class="proof-strip__grid">
		{items.map((item) => (
			<article class="proof-card surface-card surface-card--soft">
				<p class="proof-card__label">{item.label}</p>
				<p class="proof-card__copy">{item.copy}</p>
			</article>
		))}
	</div>
</section>

<style>
	.proof-strip {
		display: grid;
		gap: var(--space-4);
		margin-top: clamp(var(--space-4), 3vw, var(--space-6));
		padding: clamp(1rem, 1.8vw, 1.35rem);
		border-radius: var(--radius-lg);
	}

	.proof-strip--compact {
		padding: 0.95rem 1rem;
	}

	.proof-strip__intro {
		display: grid;
		gap: var(--space-1);
		max-width: 44rem;
	}

	.proof-strip__eyebrow,
	.proof-card__label {
		margin: 0;
		font-size: var(--font-size-xs);
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.proof-strip h2 {
		margin: 0;
		font-size: var(--font-size-heading-xl);
	}

	.proof-strip__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
		gap: var(--space-3);
	}

	.proof-card {
		display: grid;
		gap: var(--space-1);
		padding: 0.85rem;
	}

	.proof-card__copy {
		margin: 0;
		font-size: var(--font-size-ui);
		line-height: 1.55;
	}
</style>
