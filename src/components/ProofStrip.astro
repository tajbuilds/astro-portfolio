---
interface ProofItem {
	label: string;
	copy: string;
}

interface Props {
	eyebrow?: string;
	title: string;
	items: ProofItem[];
	compact?: boolean;
}

const { eyebrow, title, items, compact = false } = Astro.props;
---

<section class:list={['proof-strip', { 'proof-strip--compact': compact }]} data-reveal="soft">
	<div class="proof-strip__intro">
		{eyebrow && <p class="proof-strip__eyebrow">{eyebrow}</p>}
		<h2>{title}</h2>
	</div>
	<div class="proof-strip__grid">
		{items.map((item) => (
			<article class="proof-card">
				<p class="proof-card__label">{item.label}</p>
				<p class="proof-card__copy">{item.copy}</p>
			</article>
		))}
	</div>
</section>

<style>
	.proof-strip {
		display: grid;
		gap: 1rem;
		padding: clamp(1rem, 1.8vw, 1.35rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 18%, var(--color-border));
		border-radius: var(--radius-lg);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--color-bg-elevated) 95%, transparent), color-mix(in srgb, var(--color-bg-elevated) 90%, transparent)),
			radial-gradient(circle at top right, color-mix(in srgb, var(--color-accent) 10%, transparent), transparent 36%);
		box-shadow: var(--shadow-sm);
	}

	.proof-strip--compact {
		padding: 0.95rem 1rem;
	}

	.proof-strip__intro {
		display: grid;
		gap: 0.35rem;
		max-width: 44rem;
	}

	.proof-strip__eyebrow,
	.proof-card__label {
		margin: 0;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.proof-strip h2 {
		margin: 0;
		font-size: clamp(1.35rem, 1.1rem + 0.7vw, 1.95rem);
	}

	.proof-strip__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
		gap: 0.75rem;
	}

	.proof-card {
		display: grid;
		gap: 0.3rem;
		padding: 0.85rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-bg-elevated) 88%, transparent);
		box-shadow: var(--shadow-sm);
	}

	.proof-card__copy {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.55;
	}
</style>
