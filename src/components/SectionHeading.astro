---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<header class:list={['section-heading', `section-heading--${align}`]}>
	{eyebrow && <p class="section-heading__eyebrow">{eyebrow}</p>}
	<h2>{title}</h2>
	{description && <p class="section-heading__description">{description}</p>}
</header>

<style>
	.section-heading {
		display: grid;
		gap: var(--space-3);
		max-width: 52rem;
		margin-bottom: var(--space-6);
	}

	.section-heading--center {
		margin-inline: auto;
		text-align: center;
	}

	.section-heading__eyebrow {
		margin: 0;
		font-size: var(--font-size-xs);
		font-weight: 700;
		letter-spacing: 0.09em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.section-heading h2 {
		margin: 0;
		font-size: var(--font-size-heading-md);
	}

	.section-heading__description {
		margin: 0;
		font-size: var(--font-size-body-lg);
		line-height: 1.7;
		max-width: 44rem;
	}
</style>
