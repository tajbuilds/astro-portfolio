---
import { TURNSTILE_SITE_KEY } from '../consts';

const turnstileSiteKey = TURNSTILE_SITE_KEY;
const hasTurnstile = Boolean(turnstileSiteKey);
---
<button
	id="quick-contact-trigger"
	class="quick-contact-trigger"
	type="button"
	aria-haspopup="dialog"
	aria-controls="quick-contact-modal"
>
	Contact
</button>

<div id="quick-contact-modal" class="quick-contact-modal" hidden>
	<div class="quick-contact-backdrop" data-close-modal></div>
	<div
		class="quick-contact-panel"
		role="dialog"
		aria-modal="true"
		aria-labelledby="quick-contact-title"
	>
		<button class="quick-contact-close" type="button" aria-label="Close quick contact" data-close-modal>
			×
		</button>
		<h2 id="quick-contact-title">Quick Inquiry</h2>
		<p class="quick-contact-copy">Share a brief project context and I will reply by email.</p>

		{
			hasTurnstile ? (
				<form id="quick-contact-form" class="quick-contact-form" novalidate>
					<label>
						<span>Name</span>
						<input name="name" type="text" required minlength="2" maxlength="120" />
					</label>
					<label>
						<span>Email</span>
						<input name="email" type="email" required maxlength="190" />
					</label>
					<label>
						<span>Message</span>
						<textarea name="message" rows="2" required></textarea>
					</label>
					<input class="honeypot" type="text" name="company" tabindex="-1" autocomplete="off" />
					<div class="quick-contact-actions">
						<button type="submit">Send</button>
						<p id="quick-contact-status" class="status" role="status" aria-live="polite"></p>
					</div>
					<div class="quick-contact-turnstile">
						<div id="quick-contact-turnstile-widget" class="quick-contact-turnstile-widget"></div>
					</div>
				</form>
			) : (
				<div class="quick-contact-fallback">
					<p>Quick form is unavailable right now. Please use the full contact page.</p>
					<a href="/contact/" data-astro-prefetch>Open contact page</a>
				</div>
			)
		}
	</div>
</div>

<script is:inline define:vars={{ turnstileSiteKey }}>
	(() => {
		const QUICK_TURNSTILE_SITE_KEY = turnstileSiteKey || "";
		const trigger = document.getElementById('quick-contact-trigger');
		const modal = document.getElementById('quick-contact-modal');
		if (!(trigger instanceof HTMLButtonElement) || !(modal instanceof HTMLElement)) return;

		const form = document.getElementById('quick-contact-form');
		const statusEl = document.getElementById('quick-contact-status');
		const firstInput = form?.querySelector('input[name="name"]');
		const turnstileTarget = document.getElementById('quick-contact-turnstile-widget');
		const footer = document.querySelector('footer');

		let previousFocus = null;
		let turnstileWidgetId = null;
		let turnstileLoader = null;

		const ensureTurnstileScript = () => {
			if (!QUICK_TURNSTILE_SITE_KEY) return Promise.resolve(false);
			if (window.turnstile) return Promise.resolve(true);
			if (turnstileLoader) return turnstileLoader;

			turnstileLoader = new Promise((resolve) => {
				const existing = document.querySelector('script[data-turnstile-script="1"]');
				if (existing instanceof HTMLScriptElement) {
					existing.addEventListener('load', () => resolve(Boolean(window.turnstile)), { once: true });
					existing.addEventListener('error', () => resolve(false), { once: true });
					return;
				}

				const script = document.createElement('script');
				script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
				script.async = true;
				script.defer = true;
				script.dataset.turnstileScript = '1';
				script.addEventListener('load', () => resolve(Boolean(window.turnstile)), { once: true });
				script.addEventListener('error', () => resolve(false), { once: true });
				document.head.appendChild(script);
			});

			return turnstileLoader;
		};

		const ensureTurnstileWidget = async () => {
			if (!(turnstileTarget instanceof HTMLElement) || !QUICK_TURNSTILE_SITE_KEY) return false;
			if (turnstileWidgetId !== null) return true;

			const loaded = await ensureTurnstileScript();
			if (!loaded || !window.turnstile) return false;

			try {
				turnstileWidgetId = window.turnstile.render(turnstileTarget, {
					sitekey: QUICK_TURNSTILE_SITE_KEY,
					theme: 'auto',
					size: 'flexible',
				});
				return true;
			} catch {
				return false;
			}
		};

		const openModal = async () => {
			previousFocus = document.activeElement;
			modal.hidden = false;
			requestAnimationFrame(() => {
				modal.dataset.open = 'true';
			});
			document.body.style.overflow = 'hidden';
			if (firstInput instanceof HTMLElement) firstInput.focus();

			if (QUICK_TURNSTILE_SITE_KEY && form instanceof HTMLFormElement) {
				const ok = await ensureTurnstileWidget();
				if (!ok && statusEl instanceof HTMLElement) {
					statusEl.textContent = 'Verification unavailable. Use full contact page.';
					statusEl.dataset.error = 'true';
				}
			}
		};

		const closeModal = () => {
			modal.dataset.open = 'false';
			window.setTimeout(() => {
				modal.hidden = true;
				document.body.style.overflow = '';
				if (previousFocus instanceof HTMLElement) previousFocus.focus();
			}, 220);
		};

		trigger.addEventListener('click', openModal);
		modal.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			if (target.hasAttribute('data-close-modal')) closeModal();
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && !modal.hidden) closeModal();
		});

		if (footer && 'IntersectionObserver' in window) {
			const observer = new IntersectionObserver((entries) => {
				const visible = entries.some((entry) => entry.isIntersecting);
				trigger.classList.toggle('is-over-footer', visible);
			});
			observer.observe(footer);
		}

		if (!(form instanceof HTMLFormElement) || !(statusEl instanceof HTMLElement)) return;

		const setStatus = (message, isError = false) => {
			statusEl.textContent = message;
			statusEl.dataset.error = isError ? 'true' : 'false';
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			setStatus('Sending...');

			const formData = new FormData(form);
			const payload = {
				name: String(formData.get('name') || ''),
				email: String(formData.get('email') || ''),
				message: String(formData.get('message') || ''),
				company: String(formData.get('company') || ''),
				turnstileToken:
					turnstileWidgetId !== null && window.turnstile
						? String(window.turnstile.getResponse(turnstileWidgetId) || '')
						: '',
			};

			if (payload.name.trim().length < 2) {
				setStatus('Please enter your full name.', true);
				return;
			}

			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(payload.email.trim())) {
				setStatus('Please enter a valid email.', true);
				return;
			}

			if (!payload.message.trim()) {
				setStatus('Please enter your message.', true);
				return;
			}

			if (!payload.turnstileToken) {
				setStatus('Please complete verification.', true);
				return;
			}

			try {
				const response = await fetch('/api/contact', {
					method: 'POST',
					headers: {
						Accept: 'application/json',
						'content-type': 'application/json',
					},
					body: JSON.stringify(payload),
				});

				const data = await response.json().catch(() => ({ ok: false, message: 'Unexpected response.' }));
				if (!response.ok || !data.ok) {
					setStatus(data.message || 'Unable to send message.', true);
					return;
				}

				form.reset();
				if (window.turnstile && turnstileWidgetId !== null) {
					window.turnstile.reset(turnstileWidgetId);
				}
				setStatus('Message sent. Thank you.');
				setTimeout(closeModal, 700);
			} catch {
				setStatus('Network error. Please try again.', true);
			}
		});
	})();
</script>

<style>
	.quick-contact-trigger {
		position: fixed;
		right: 1rem;
		bottom: 1rem;
		z-index: 95;
		border: 1px solid var(--color-accent);
		background: var(--color-accent);
		color: #fff;
		font: inherit;
		font-weight: 700;
		padding: 0.62rem 0.95rem;
		border-radius: 999px;
		cursor: pointer;
		box-shadow: var(--shadow-sm);
		transition:
			bottom var(--motion-base) var(--ease-standard),
			transform var(--motion-fast) var(--ease-standard),
			background-color var(--motion-fast) var(--ease-standard),
			box-shadow var(--motion-base) var(--ease-standard);
	}

	.quick-contact-trigger::after {
		content: '';
		position: absolute;
		inset: -0.3rem;
		border-radius: inherit;
		border: 1px solid color-mix(in srgb, var(--color-accent) 28%, transparent);
		opacity: 0;
		transform: scale(0.92);
		transition: opacity var(--motion-base) var(--ease-standard), transform var(--motion-base) var(--ease-emphasis);
		pointer-events: none;
	}

	.quick-contact-trigger:hover {
		background: var(--color-accent-strong);
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
	}

	.quick-contact-trigger:hover::after {
		opacity: 1;
		transform: scale(1);
	}

	.quick-contact-trigger.is-over-footer {
		bottom: 5.2rem;
	}

	.quick-contact-modal {
		position: fixed;
		inset: 0;
		z-index: 140;
	}

	.quick-contact-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(2, 6, 23, 0.64);
		backdrop-filter: blur(8px);
		opacity: 0;
		transition: opacity var(--motion-base) var(--ease-standard);
	}

	.quick-contact-panel {
		position: absolute;
		right: 1rem;
		bottom: 4.4rem;
		width: min(23.5rem, calc(100vw - 1.2rem));
		padding: 0.82rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background: var(--color-bg-elevated);
		box-shadow: var(--shadow-lg);
		opacity: 0;
		transform: translate3d(0, 12px, 0) scale(0.97);
		transform-origin: bottom right;
		transition:
			opacity var(--motion-base) var(--ease-standard),
			transform var(--motion-base) var(--ease-emphasis);
	}

	.quick-contact-modal[data-open='true'] .quick-contact-backdrop {
		opacity: 1;
	}

	.quick-contact-modal[data-open='true'] .quick-contact-panel {
		opacity: 1;
		transform: translate3d(0, 0, 0) scale(1);
	}

	.quick-contact-close {
		position: absolute;
		top: 0.45rem;
		right: 0.45rem;
		border: 0;
		background: transparent;
		color: var(--color-text-muted);
		font-size: 1.05rem;
		line-height: 1;
		cursor: pointer;
	}

	.quick-contact-panel h2 {
		margin: 0 0 0.2rem;
		font-size: 1.05rem;
	}

	.quick-contact-copy {
		margin: 0 0 0.55rem;
		font-size: 0.84rem;
	}

	.quick-contact-form {
		display: grid;
		gap: 0.42rem;
	}

	.quick-contact-form label {
		display: grid;
		gap: 0.2rem;
	}

	.quick-contact-form span {
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--color-text);
	}

	.quick-contact-form input,
	.quick-contact-form textarea {
		width: 100%;
		font: inherit;
		padding: 0.46rem 0.58rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg-elevated);
		color: var(--color-text);
	}

	.quick-contact-form textarea {
		resize: vertical;
		min-height: 2.2rem;
	}

	.quick-contact-form small {
		font-size: 0.72rem;
		color: var(--color-text-muted);
	}

	.quick-contact-turnstile {
		margin-top: 0.1rem;
	}

	.quick-contact-turnstile-widget {
		max-width: 100%;
	}

	.quick-contact-actions {
		display: grid;
		gap: 0.3rem;
	}

	.quick-contact-actions button {
		width: fit-content;
		border: 1px solid var(--color-accent);
		background: var(--color-accent);
		color: #fff;
		font: inherit;
		font-weight: 700;
		padding: 0.38rem 0.7rem;
		border-radius: 999px;
		cursor: pointer;
	}

	.quick-contact-actions button:hover {
		background: var(--color-accent-strong);
	}

	.status {
		margin: 0;
		font-size: 0.76rem;
		color: var(--color-text-muted);
	}

	.status[data-error='true'] {
		color: #ef4444;
	}

	.quick-contact-fallback p {
		margin-bottom: 0.5rem;
	}

	.honeypot {
		position: absolute;
		left: -9999px;
		opacity: 0;
		pointer-events: none;
	}

	@media (max-width: 720px) {
		.quick-contact-trigger {
			right: 0.7rem;
			bottom: 0.7rem;
		}

		.quick-contact-trigger.is-over-footer {
			bottom: 4.7rem;
		}

		.quick-contact-panel {
			right: 0.35rem;
			bottom: 3.7rem;
			width: min(23.5rem, calc(100vw - 0.7rem));
		}
	}

	@media (max-width: 420px) {
		.quick-contact-trigger {
			padding: 0.55rem 0.82rem;
		}

		.quick-contact-panel {
			max-height: 78vh;
			overflow: auto;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.quick-contact-trigger,
		.quick-contact-trigger::after,
		.quick-contact-backdrop,
		.quick-contact-panel {
			transition: none;
		}

		.quick-contact-trigger:hover {
			transform: none;
		}
	}
</style>
