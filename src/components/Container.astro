---
interface Props {
	size?: 'narrow' | 'wide' | 'full';
	as?: 'div' | 'section';
	class?: string;
}

const { size = 'wide', as = 'div', class: className } = Astro.props;
const Tag = as;
---

<Tag class:list={['container', `container--${size}`, className]}>
	<slot />
</Tag>

<style>
	.container {
		width: 100%;
		margin-inline: auto;
	}

	.container--narrow {
		max-width: var(--container-size-narrow);
	}

	.container--wide {
		max-width: var(--container-size-wide);
	}

	.container--full {
		max-width: var(--container-size-full);
	}
</style>
