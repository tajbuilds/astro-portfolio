---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p>&copy; {today.getFullYear()} Tajinder Singh. Built with Astro and deployed on Cloudflare.</p>
		<div class="footer-links">
			<a href="mailto:contact@tajs.io">Email</a>
			<a href="https://www.linkedin.com/in/taj-tajinder/" target="_blank" rel="noreferrer">LinkedIn</a>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: clamp(1rem, 2vw, 1.4rem) 1.25rem;
		border-top: 1px solid var(--color-border);
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.footer-inner {
		max-width: var(--container-narrow);
		margin: 0 auto;
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		gap: 0.85rem 1rem;
	}

	footer p {
		margin: 0;
		font-size: 0.88rem;
		color: rgb(var(--gray));
	}

	.footer-links {
		display: flex;
		gap: 0.9rem;
	}

	.footer-links a {
		font-size: 0.88rem;
		font-weight: 600;
		text-decoration: none;
	}

	@media (max-width: 720px) {
		.footer-inner {
			align-items: flex-start;
		}
	}
</style>