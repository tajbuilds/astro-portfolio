---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-identity">
			<img
				class="footer-avatar"
				src="/images/tajinder-singh-portrait.jpg"
				alt="Portrait of Tajinder Singh"
				loading="lazy"
				width="36"
				height="36"
			/>
			<div class="footer-links" aria-label="Footer contact links">
				<a
					class="footer-icon-link"
					href="mailto:contact@tajs.io"
					aria-label="Email Tajinder Singh"
					title="Email"
				>
					<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
						<path d="M3 6h18v12H3z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
						<path d="M3 7l9 7 9-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
					<span class="sr-only">Email</span>
				</a>
				<a
					class="footer-icon-link"
					href="https://www.linkedin.com/in/taj-tajinder/"
					target="_blank"
					rel="noreferrer"
					aria-label="LinkedIn profile"
					title="LinkedIn"
				>
					<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
						<path d="M4 9h4v11H4zM6 4a2 2 0 110 4 2 2 0 010-4zM11 9h4v1.8c.8-1.3 1.9-2.2 4.1-2.2 3.3 0 4.9 2.1 4.9 6V20h-4v-4.7c0-2.2-.8-3-2.2-3-1.6 0-2.8 1.1-2.8 3.1V20h-4z" fill="currentColor"/>
					</svg>
					<span class="sr-only">LinkedIn</span>
				</a>
				<a
					class="footer-icon-link"
					href="https://github.com/tajbuilds"
					target="_blank"
					rel="noreferrer"
					aria-label="GitHub profile"
					title="GitHub"
				>
					<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
						<path
							fill="currentColor"
							d="M12 2a10 10 0 00-3.162 19.487c.5.093.683-.217.683-.482 0-.238-.009-.87-.013-1.707-2.781.604-3.369-1.34-3.369-1.34-.455-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.004.071 1.532 1.031 1.532 1.031.893 1.531 2.343 1.089 2.914.833.091-.647.35-1.09.636-1.341-2.221-.253-4.555-1.11-4.555-4.941 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.271.098-2.649 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844a9.56 9.56 0 012.504.337c1.909-1.294 2.748-1.025 2.748-1.025.546 1.378.203 2.396.1 2.649.64.699 1.028 1.592 1.028 2.683 0 3.84-2.338 4.685-4.566 4.933.359.309.679.92.679 1.854 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.481A10 10 0 0012 2z"
						/>
					</svg>
					<span class="sr-only">GitHub</span>
				</a>
				<a
					class="footer-icon-link"
					href="https://play.google.com/store/apps/details?id=com.tajbuilds.portfolio"
					target="_blank"
					rel="noreferrer"
					aria-label="Google Play app"
					title="Google Play"
				>
					<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
						<path
							fill="currentColor"
							d="M3 20.6V3.4c0-.8.8-1.3 1.5-.9L18.8 10.7c.7.4.7 1.3 0 1.7L4.5 21.5c-.7.4-1.5-.1-1.5-.9Z"
						/>
					</svg>
					<span class="sr-only">Google Play</span>
				</a>
			</div>
		</div>
		<div class="footer-meta">
			<p>&copy; {today.getFullYear()} Tajinder Singh. Built with Astro and deployed on Cloudflare.</p>
			<div class="footer-legal">
				<a class="privacy-link" href="/privacy">Privacy</a>
				<button id="analytics-settings-trigger" type="button" class="privacy-link analytics-settings-button">
					Analytics settings
				</button>
			</div>
		</div>
	</div>
</footer>

<script is:inline>
	(() => {
		const trigger = document.getElementById('analytics-settings-trigger');
		if (!(trigger instanceof HTMLButtonElement)) return;
		trigger.addEventListener('click', () => {
			window.dispatchEvent(new Event('analytics:open-settings'));
		});
	})();
</script>

<style>
	footer {
		padding: clamp(1rem, 2vw, 1.5rem) var(--space-inline);
		border-top: 1px solid var(--color-border);
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.footer-inner {
		max-width: var(--container-size-full);
		margin: 0 auto;
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-4) var(--space-5);
		align-items: center;
	}

	.footer-identity {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		flex-wrap: wrap;
	}

	.footer-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-3);
		flex-wrap: wrap;
	}

	.footer-avatar {
		width: 2.1rem;
		height: 2.1rem;
		object-fit: cover;
		border-radius: 999px;
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-sm);
	}

	footer p {
		margin: 0;
		font-size: var(--font-size-sm);
		color: rgb(var(--gray));
	}

	.footer-legal {
		display: inline-flex;
		align-items: center;
		gap: var(--space-3);
		flex-wrap: wrap;
	}

	.privacy-link {
		font-family: inherit;
		font-size: var(--font-size-sm);
		color: var(--color-text-muted);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition:
			color var(--motion-fast) var(--ease-standard),
			border-color var(--motion-fast) var(--ease-standard);
	}

	.analytics-settings-button {
		appearance: none;
		background: transparent;
		border: 0;
		padding: 0;
		cursor: pointer;
	}

	.privacy-link:hover {
		color: var(--color-accent);
		border-color: var(--color-accent);
	}

	.footer-links {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		flex-wrap: nowrap;
	}

	.footer-icon-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--color-accent);
		text-decoration: none;
		padding: 0.18rem;
		border-radius: 0.35rem;
		border: 1px solid transparent;
		transition:
			color var(--motion-fast) var(--ease-standard),
			opacity var(--motion-fast) var(--ease-standard),
			border-color var(--motion-fast) var(--ease-standard),
			background-color var(--motion-fast) var(--ease-standard),
			transform var(--motion-fast) var(--ease-standard);
	}

	.footer-icon-link:hover {
		color: var(--color-accent-strong);
		opacity: 0.9;
		transform: translateY(-1px);
		border-color: color-mix(in srgb, var(--color-accent) 20%, transparent);
		background: color-mix(in srgb, var(--color-accent) 8%, transparent);
	}

	.footer-icon-link:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.footer-icon-link svg {
		width: 1rem;
		height: 1rem;
	}

	@media (max-width: 760px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: var(--space-3);
			align-items: start;
		}

		.footer-meta {
			align-items: start;
			justify-content: flex-start;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.footer-icon-link {
			transition: none;
		}

		.footer-icon-link:hover {
			transform: none;
		}
	}
</style>
