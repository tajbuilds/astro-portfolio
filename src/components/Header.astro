---
import HeaderLink from './HeaderLink.astro';
import { SITE_BRAND } from '../consts';
---

<header>
	<nav aria-label="Primary">
		<a class="brand" href="/" data-astro-prefetch>{SITE_BRAND}</a>
		<div class="nav-controls">
			<div class="internal-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/work">Work</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/contact">Contact</HeaderLink>
			</div>
			<button
				id="theme-toggle"
				class="theme-toggle"
				type="button"
				aria-label="Switch to dark theme"
				aria-pressed="false"
			>
				<span class="theme-swatch" aria-hidden="true">
					<span class="theme-swatch__light"></span>
					<span class="theme-swatch__dark"></span>
					<span class="theme-swatch__thumb"></span>
				</span>
				<span id="theme-toggle-text" class="sr-only">Switch to dark theme</span>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	(() => {
		const storageKey = 'theme';
		const root = document.documentElement;
		const toggle = document.getElementById('theme-toggle');
		const srText = document.getElementById('theme-toggle-text');
		const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

		if (!toggle || !srText) {
			return;
		}

		const getPreferredTheme = () => {
			const storedTheme = localStorage.getItem(storageKey);
			if (storedTheme === 'dark' || storedTheme === 'light') {
				return storedTheme;
			}
			return mediaQuery.matches ? 'dark' : 'light';
		};

		const applyTheme = (theme) => {
			const isDark = theme === 'dark';
			const nextLabel = isDark ? 'Switch to light theme' : 'Switch to dark theme';
			root.dataset.theme = isDark ? 'dark' : 'light';
			toggle.dataset.theme = isDark ? 'dark' : 'light';
			toggle.setAttribute('aria-pressed', String(isDark));
			toggle.setAttribute('aria-label', nextLabel);
			toggle.setAttribute('title', nextLabel);
			srText.textContent = nextLabel;
		};

		applyTheme(getPreferredTheme());

		toggle.addEventListener('click', () => {
			const currentTheme = root.dataset.theme === 'dark' ? 'dark' : 'light';
			const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
			localStorage.setItem(storageKey, nextTheme);
			applyTheme(nextTheme);
		});

		mediaQuery.addEventListener('change', () => {
			const storedTheme = localStorage.getItem(storageKey);
			if (storedTheme === 'dark' || storedTheme === 'light') {
				return;
			}
			applyTheme(getPreferredTheme());
		});
	})();
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 0.85rem 1.2rem;
		backdrop-filter: blur(12px);
		background: color-mix(in srgb, var(--color-bg-elevated) 82%, transparent);
		border-bottom: 1px solid var(--color-border);
	}

	nav {
		max-width: var(--container-full);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.brand {
		font-size: 0.92rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-decoration: none;
		text-transform: uppercase;
		color: var(--color-text);
	}

	.nav-controls {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.55rem;
	}

	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.22rem;
		border-radius: 999px;
		border: 1px solid var(--color-border);
		background: var(--color-bg-elevated);
		box-shadow: var(--shadow-sm);
		cursor: pointer;
		transition: transform 120ms ease, border-color 120ms ease;
	}

	.theme-toggle:hover {
		transform: translateY(-1px);
		border-color: var(--color-accent);
	}

	.theme-toggle:active {
		transform: translateY(0);
	}

	.theme-swatch {
		position: relative;
		display: grid;
		grid-template-columns: 1fr 1fr;
		width: 2.2rem;
		height: 1.2rem;
		overflow: hidden;
		border-radius: 999px;
	}

	.theme-swatch__light {
		background: #f8fafc;
	}

	.theme-swatch__dark {
		background: #0f172a;
	}

	.theme-swatch__thumb {
		position: absolute;
		top: 0.13rem;
		left: 0.13rem;
		width: 0.94rem;
		height: 0.94rem;
		border-radius: 999px;
		background: #ffffff;
		border: 1px solid rgba(15, 23, 42, 0.2);
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.3);
		transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
	}

	.theme-toggle[data-theme='dark'] .theme-swatch__thumb {
		transform: translateX(1rem);
		background: #dbeafe;
		border-color: rgba(147, 197, 253, 0.45);
	}

	@media (max-width: 980px) {
		nav {
			align-items: flex-start;
		}

		.nav-controls {
			flex-direction: column;
			align-items: flex-end;
		}

		.internal-links {
			flex-wrap: wrap;
			justify-content: flex-end;
		}
	}

	@media (max-width: 700px) {
		header {
			padding-inline: 0.9rem;
		}

		nav,
		.nav-controls {
			align-items: center;
		}

		nav {
			flex-direction: column;
		}

		.internal-links {
			justify-content: center;
		}
	}
</style>


