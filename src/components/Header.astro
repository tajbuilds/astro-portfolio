---
import HeaderLink from './HeaderLink.astro';
import { SITE_BRAND } from '../consts';
---

<header>
	<nav aria-label="Primary">
		<a class="brand" href="/" data-astro-prefetch>{SITE_BRAND}</a>
		<div class="nav-controls">
			<div class="internal-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/work">Work</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/contact">Contact</HeaderLink>
			</div>
			<div class="theme-picker" id="theme-picker">
				<button
					id="theme-picker-button"
					class="theme-picker__button"
					type="button"
					aria-haspopup="menu"
					aria-expanded="false"
					aria-controls="theme-picker-menu"
				>
					<span class="theme-picker__icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" focusable="false">
							<path
								d="M20.25 15.5A8.75 8.75 0 0 1 8.5 3.75a8.75 8.75 0 1 0 11.75 11.75Z"
								stroke="currentColor"
								stroke-width="1.7"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					</span>
					<span class="theme-picker__label" id="theme-picker-label">System</span>
					<span class="theme-picker__chevron" aria-hidden="true">
						<svg viewBox="0 0 16 16" fill="none" focusable="false">
							<path d="M4 6.5 8 10l4-3.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</span>
				</button>
				<div id="theme-picker-menu" class="theme-picker__menu" role="menu" hidden>
					<button type="button" class="theme-picker__option" role="menuitemradio" data-theme-option="system" aria-checked="false">System</button>
					<button type="button" class="theme-picker__option" role="menuitemradio" data-theme-option="light" aria-checked="false">Light</button>
					<button type="button" class="theme-picker__option" role="menuitemradio" data-theme-option="dark" aria-checked="false">Midnight</button>
					<button type="button" class="theme-picker__option" role="menuitemradio" data-theme-option="mist" aria-checked="false">Mist</button>
					<button type="button" class="theme-picker__option" role="menuitemradio" data-theme-option="forest" aria-checked="false">Forest</button>
					<button type="button" class="theme-picker__option" role="menuitemradio" data-theme-option="dusk" aria-checked="false">Dusk</button>
					<button type="button" class="theme-picker__option" role="menuitemradio" data-theme-option="sand" aria-checked="false">Sand</button>
				</div>
			</div>
		</div>
	</nav>
</header>

<script is:inline>
	(() => {
		const storageKey = 'theme';
		const allowedThemes = new Set(['system', 'light', 'dark', 'mist', 'forest', 'dusk', 'sand']);
		const root = document.documentElement;
		const picker = document.getElementById('theme-picker');
		const button = document.getElementById('theme-picker-button');
		const label = document.getElementById('theme-picker-label');
		const menu = document.getElementById('theme-picker-menu');
		const options = Array.from(document.querySelectorAll('[data-theme-option]'));
		const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

		if (!(picker instanceof HTMLElement) || !(button instanceof HTMLButtonElement) || !(label instanceof HTMLElement) || !(menu instanceof HTMLDivElement)) {
			return;
		}

		const getStoredPreference = () => {
			const storedTheme = localStorage.getItem(storageKey);
			return allowedThemes.has(storedTheme || '') ? storedTheme : 'system';
		};

		const resolveTheme = (preference) => {
			if (preference === 'system') {
				return mediaQuery.matches ? 'dark' : 'light';
			}
			return preference;
		};

		const themeLabels = {
			system: 'Theme: System',
			light: 'Theme: Light',
			dark: 'Theme: Midnight',
			mist: 'Theme: Mist',
			forest: 'Theme: Forest',
			dusk: 'Theme: Dusk',
			sand: 'Theme: Sand',
		};

		const buttonLabels = {
			system: 'System',
			light: 'Light',
			dark: 'Midnight',
			mist: 'Mist',
			forest: 'Forest',
			dusk: 'Dusk',
			sand: 'Sand',
		};

		const closeMenu = () => {
			picker.dataset.open = 'false';
			button.setAttribute('aria-expanded', 'false');
			window.setTimeout(() => {
				if (button.getAttribute('aria-expanded') === 'false') {
					menu.hidden = true;
				}
			}, 140);
		};

		const openMenu = () => {
			menu.hidden = false;
			button.setAttribute('aria-expanded', 'true');
			requestAnimationFrame(() => {
				picker.dataset.open = 'true';
			});
		};

		const applyTheme = (preference) => {
			const resolvedTheme = resolveTheme(preference);
			root.dataset.theme = resolvedTheme;
			root.dataset.themePreference = preference;
			picker.dataset.theme = resolvedTheme;
			button.title = themeLabels[preference] || 'Theme';
			label.textContent = buttonLabels[preference] || 'System';
			options.forEach((option) => {
				if (!(option instanceof HTMLButtonElement)) return;
				option.setAttribute('aria-checked', String(option.dataset.themeOption === preference));
			});
		};

		applyTheme(getStoredPreference());

		button.addEventListener('click', () => {
			if (menu.hidden) openMenu();
			else closeMenu();
		});

		options.forEach((option) => {
			if (!(option instanceof HTMLButtonElement)) return;
			option.addEventListener('click', () => {
				const nextTheme = allowedThemes.has(option.dataset.themeOption || '') ? option.dataset.themeOption : 'system';
				localStorage.setItem(storageKey, nextTheme);
				applyTheme(nextTheme);
				closeMenu();
				button.focus();
			});
		});

		document.addEventListener('click', (event) => {
			if (!(event.target instanceof Node)) return;
			if (!picker.contains(event.target)) closeMenu();
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				closeMenu();
				button.focus();
			}
		});

		menu.addEventListener('keydown', (event) => {
			const currentIndex = options.findIndex((option) => option === document.activeElement);
			if (event.key === 'ArrowDown') {
				event.preventDefault();
				const next = options[(currentIndex + 1 + options.length) % options.length];
				if (next instanceof HTMLButtonElement) next.focus();
			}
			if (event.key === 'ArrowUp') {
				event.preventDefault();
				const next = options[(currentIndex - 1 + options.length) % options.length];
				if (next instanceof HTMLButtonElement) next.focus();
			}
		});

		button.addEventListener('keydown', (event) => {
			if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
				event.preventDefault();
				openMenu();
				const checked = options.find((option) => option instanceof HTMLButtonElement && option.getAttribute('aria-checked') === 'true');
				if (checked instanceof HTMLButtonElement) checked.focus();
			}
		});

		mediaQuery.addEventListener('change', () => {
			if (getStoredPreference() !== 'system') {
				return;
			}
			applyTheme('system');
		});
	})();
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 0.85rem 1.2rem;
		backdrop-filter: blur(12px);
		background: color-mix(in srgb, var(--color-bg-elevated) 82%, transparent);
		border-bottom: 1px solid var(--color-border);
	}

	nav {
		max-width: var(--container-full);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.brand {
		font-size: 0.92rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-decoration: none;
		text-transform: uppercase;
		color: var(--color-text);
	}

	.nav-controls {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.55rem;
	}

	.theme-picker {
		display: inline-flex;
		align-items: center;
		position: relative;
		isolation: isolate;
	}

	.theme-picker__button {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: flex-start;
		min-width: 6.45rem;
		padding: 0.45rem 1.75rem 0.45rem 1.8rem;
		border: 1px solid var(--color-border);
		background: color-mix(in srgb, var(--color-bg-elevated) 88%, var(--color-surface));
		box-shadow: var(--shadow-sm);
		border-radius: 999px;
		color-scheme: var(--theme-color-scheme, light);
		color: var(--color-text);
		font: inherit;
		cursor: pointer;
		overflow: hidden;
		transition: transform 120ms ease, border-color 120ms ease, background 180ms ease, box-shadow 180ms ease;
	}

	.theme-picker__button::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 10%, transparent), transparent 55%);
		opacity: 0;
		transition: opacity 180ms ease;
	}

	.theme-picker__button:hover {
		transform: translateY(-1px);
		border-color: var(--color-accent);
	}

	.theme-picker__button:hover::before,
	.theme-picker[data-open='true'] .theme-picker__button::before {
		opacity: 1;
	}

	.theme-picker__button:active {
		transform: translateY(0);
	}

	.theme-picker__icon,
	.theme-picker__chevron {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		pointer-events: none;
		color: var(--color-text-muted);
	}

	.theme-picker__icon {
		left: 0.72rem;
		width: 1rem;
		height: 1rem;
	}

	.theme-picker__chevron {
		right: 0.72rem;
		width: 0.9rem;
		height: 0.9rem;
		transition: transform 180ms ease, color 180ms ease;
	}

	.theme-picker[data-open='true'] .theme-picker__chevron {
		transform: translateY(-50%) rotate(180deg);
		color: var(--color-accent);
	}

	.theme-picker__icon svg,
	.theme-picker__chevron svg {
		display: block;
		width: 100%;
		height: 100%;
	}

	.theme-picker__label {
		display: block;
		position: relative;
		z-index: 1;
		padding-right: 0.15rem;
		font-size: 0.88rem;
		line-height: 1.2;
	}

	.theme-picker__button:focus {
		outline: none;
	}

	.theme-picker__button:focus-visible {
		border-color: var(--color-accent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 16%, transparent), var(--shadow-sm);
	}

	.theme-picker__menu {
		position: absolute;
		top: calc(100% + 0.45rem);
		right: 0;
		z-index: 110;
		min-width: 100%;
		padding: 0.35rem;
		border: 1px solid var(--color-border);
		border-radius: 0.8rem;
		background: color-mix(in srgb, var(--color-bg-elevated) 94%, var(--color-surface));
		box-shadow: var(--shadow-md);
		transform-origin: top right;
		opacity: 0;
		transform: translateY(-0.35rem) scale(0.97);
		transition: opacity 140ms ease, transform 140ms ease;
	}

	.theme-picker[data-open='true'] .theme-picker__menu {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	.theme-picker__option {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		padding: 0.48rem 0.6rem;
		border: 0;
		border-radius: 0.5rem;
		background: transparent;
		color: var(--color-text);
		font: inherit;
		font-size: 0.88rem;
		text-align: left;
		cursor: pointer;
	}

	.theme-picker__option:hover,
	.theme-picker__option:focus-visible {
		background: color-mix(in srgb, var(--color-accent) 12%, transparent);
		outline: none;
	}

	.theme-picker__option[aria-checked='true'] {
		color: var(--color-accent-strong);
		background: color-mix(in srgb, var(--color-accent) 14%, transparent);
		font-weight: 600;
	}

	.theme-picker__option[aria-checked='true']::after {
		content: '•';
		font-size: 1.1rem;
	}

	.theme-picker[data-theme='mist'] .theme-picker__icon {
		color: #5b82a6;
	}

	.theme-picker[data-theme='forest'] .theme-picker__icon {
		color: #8bc7a2;
	}

	.theme-picker[data-theme='dusk'] .theme-picker__icon {
		color: #c6a7f2;
	}

	.theme-picker[data-theme='sand'] .theme-picker__icon {
		color: #b68d5f;
	}

	@media (prefers-reduced-motion: reduce) {
		.theme-picker__button,
		.theme-picker__button::before,
		.theme-picker__chevron,
		.theme-picker__menu {
			transition: none;
		}
	}

	@media (max-width: 980px) {
		nav {
			align-items: flex-start;
		}

		.nav-controls {
			flex-direction: column;
			align-items: flex-end;
		}

		.internal-links {
			flex-wrap: wrap;
			justify-content: flex-end;
		}
	}

	@media (max-width: 700px) {
		header {
			padding-inline: 0.9rem;
		}

		nav,
		.nav-controls {
			align-items: center;
		}

		nav {
			flex-direction: column;
		}

		.internal-links {
			justify-content: center;
		}
	}
</style>


