---
import HeaderLink from './HeaderLink.astro';
import { SITE_BRAND } from '../consts';
---

<header>
	<nav aria-label="Primary">
		<a class="brand" href="/" data-astro-prefetch>{SITE_BRAND}</a>
		<div class="nav-controls">
			<div class="internal-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/work">Work</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/contact">Contact</HeaderLink>
			</div>
			<div class="theme-picker" id="theme-picker">
				<label class="theme-picker__control" for="theme-select">
					<span class="theme-picker__icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" focusable="false">
							<path
								d="M20.25 15.5A8.75 8.75 0 0 1 8.5 3.75a8.75 8.75 0 1 0 11.75 11.75Z"
								stroke="currentColor"
								stroke-width="1.7"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					</span>
					<span class="sr-only">Select theme</span>
					<select id="theme-select" class="theme-picker__select" aria-label="Select theme">
						<option value="system">System</option>
						<option value="light">Light</option>
						<option value="dark">Dark</option>
						<option value="paper">Paper</option>
						<option value="ocean">Ocean</option>
					</select>
					<span class="theme-picker__chevron" aria-hidden="true">
						<svg viewBox="0 0 16 16" fill="none" focusable="false">
							<path d="M4 6.5 8 10l4-3.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</span>
				</label>
			</div>
		</div>
	</nav>
</header>

<script is:inline>
	(() => {
		const storageKey = 'theme';
		const allowedThemes = new Set(['system', 'light', 'dark', 'paper', 'ocean']);
		const root = document.documentElement;
		const picker = document.getElementById('theme-picker');
		const select = document.getElementById('theme-select');
		const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

		if (!(picker instanceof HTMLElement) || !(select instanceof HTMLSelectElement)) {
			return;
		}

		const getStoredPreference = () => {
			const storedTheme = localStorage.getItem(storageKey);
			return allowedThemes.has(storedTheme || '') ? storedTheme : 'system';
		};

		const resolveTheme = (preference) => {
			if (preference === 'system') {
				return mediaQuery.matches ? 'dark' : 'light';
			}
			return preference;
		};

		const themeLabels = {
			system: 'Theme: System',
			light: 'Theme: Light',
			dark: 'Theme: Dark',
			paper: 'Theme: Paper',
			ocean: 'Theme: Ocean',
		};

		const applyTheme = (preference) => {
			const resolvedTheme = resolveTheme(preference);
			root.dataset.theme = resolvedTheme;
			root.dataset.themePreference = preference;
			picker.dataset.theme = resolvedTheme;
			select.value = preference;
			select.title = themeLabels[preference] || 'Theme';
		};

		applyTheme(getStoredPreference());

		select.addEventListener('change', () => {
			const nextTheme = allowedThemes.has(select.value) ? select.value : 'system';
			localStorage.setItem(storageKey, nextTheme);
			applyTheme(nextTheme);
		});

		mediaQuery.addEventListener('change', () => {
			if (getStoredPreference() !== 'system') {
				return;
			}
			applyTheme('system');
		});
	})();
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 0.85rem 1.2rem;
		backdrop-filter: blur(12px);
		background: color-mix(in srgb, var(--color-bg-elevated) 82%, transparent);
		border-bottom: 1px solid var(--color-border);
	}

	nav {
		max-width: var(--container-full);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.brand {
		font-size: 0.92rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-decoration: none;
		text-transform: uppercase;
		color: var(--color-text);
	}

	.nav-controls {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.55rem;
	}

	.theme-picker {
		display: inline-flex;
		align-items: center;
	}

	.theme-picker__control {
		position: relative;
		display: inline-flex;
		align-items: center;
		min-width: 9rem;
		padding: 0;
		border: 1px solid var(--color-border);
		background: var(--color-bg-elevated);
		box-shadow: var(--shadow-sm);
		border-radius: 999px;
		transition: transform 120ms ease, border-color 120ms ease;
	}

	.theme-picker__control:hover {
		transform: translateY(-1px);
		border-color: var(--color-accent);
	}

	.theme-picker__control:active {
		transform: translateY(0);
	}

	.theme-picker__icon,
	.theme-picker__chevron {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		pointer-events: none;
		color: var(--color-text-muted);
	}

	.theme-picker__icon {
		left: 0.72rem;
		width: 1rem;
		height: 1rem;
	}

	.theme-picker__chevron {
		right: 0.72rem;
		width: 0.9rem;
		height: 0.9rem;
	}

	.theme-picker__icon svg,
	.theme-picker__chevron svg {
		display: block;
		width: 100%;
		height: 100%;
	}

	.theme-picker__select {
		appearance: none;
		width: 100%;
		padding: 0.52rem 2rem 0.52rem 2rem;
		border: 0;
		border-radius: 999px;
		background: transparent;
		color: var(--color-text);
		font: inherit;
		font-size: 0.88rem;
		line-height: 1.2;
		cursor: pointer;
	}

	.theme-picker__select:focus {
		outline: none;
	}

	.theme-picker__select option {
		color: #121826;
	}

	.theme-picker[data-theme='paper'] .theme-picker__icon {
		color: #a25636;
	}

	.theme-picker[data-theme='ocean'] .theme-picker__icon {
		color: #57e3f4;
	}

	@media (max-width: 980px) {
		nav {
			align-items: flex-start;
		}

		.nav-controls {
			flex-direction: column;
			align-items: flex-end;
		}

		.internal-links {
			flex-wrap: wrap;
			justify-content: flex-end;
		}
	}

	@media (max-width: 700px) {
		header {
			padding-inline: 0.9rem;
		}

		nav,
		.nav-controls {
			align-items: center;
		}

		nav {
			flex-direction: column;
		}

		.internal-links {
			justify-content: center;
		}
	}
</style>


