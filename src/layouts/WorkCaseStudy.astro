---
import MainLayout from './MainLayout.astro';
import PillTag from '../components/PillTag.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ProofStrip from '../components/ProofStrip.astro';
import { getWorkProofItems } from '../lib/proof-data';

interface AdjacentLink {
	title: string;
	slug: string;
}

interface WorkHeading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	slug: string;
	title: string;
	description: string;
	date: Date;
	updatedDate?: Date;
	tags: string[];
	coverImage?: string;
	imageAlt?: string;
	github?: string;
	externalCaseStudyUrl?: string;
	headings?: WorkHeading[];
	readingTime?: number;
	previous?: AdjacentLink;
	next?: AdjacentLink;
	seoTitle?: string;
	seoDescription?: string;
	keywords?: string[];
}

const {
	slug,
	title,
	description,
	date,
	updatedDate,
	tags,
	coverImage,
	imageAlt,
	github,
	externalCaseStudyUrl,
	headings = [],
	readingTime,
	previous,
	next,
	seoTitle,
	seoDescription,
	keywords = [],
} = Astro.props;
const isExternalCaseStudyLink = Boolean(externalCaseStudyUrl && /^https?:\/\//i.test(externalCaseStudyUrl));
const tocItems = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const proofItems = getWorkProofItems(slug);
---

<MainLayout
	title={seoTitle || `${title} | Work`}
	description={seoDescription || description}
	image={coverImage}
	imageAlt={imageAlt}
	type="article"
	publishedTime={date}
	modifiedTime={updatedDate || date}
	keywords={keywords}
	width="full"
>
	<article class="work-article">
		<a class="back-link" href="/work" data-reveal="soft">&larr; Back to Work</a>
		<header class="work-header surface-card surface-card--feature" data-reveal="soft">
			<p class="work-label">Case Study</p>
			<h1>{title}</h1>
			<p class="work-description">{description}</p>
			<div class="work-meta">
				<span><FormattedDate date={date} /></span>
				{readingTime && <span>{readingTime} min read</span>}
				{github && (
					<a href={github} target="_blank" rel="noreferrer">GitHub</a>
				)}
			</div>
			<div class="work-tags">
				{tags.map((tag) => <PillTag label={tag} href={`/work/tags/${tag.toLowerCase().replace(/[^a-z0-9]+/g, '-')}/`} />)}
			</div>
		</header>
		{coverImage && (
			<section class="work-feature-media surface-card surface-card--feature" data-reveal="soft" aria-label="Featured case study media">
				<div class="work-feature-media__frame">
					<img src={coverImage} alt={`${title} architecture diagram or featured media`} loading="lazy" />
				</div>
				<div class="work-feature-media__meta surface-card surface-card--soft">
					<p class="work-feature-media__eyebrow">Architecture View</p>
					<p class="work-feature-media__copy">
						A supporting visual for the system shape, flow, or delivery model used in this case study.
					</p>
				</div>
			</section>
		)}
		{proofItems.length > 0 && (
			<ProofStrip
				eyebrow="Selected Outcomes"
				title="What changed because of the work"
				items={proofItems}
				compact={true}
			/>
		)}
		<div class="work-body">
			{tocItems.length > 0 && (
				<aside class="work-toc surface-card surface-card--soft" aria-label="On this page" data-reveal="left">
					<p class="work-toc__label">On this page</p>
					<nav>
						<ul>
							{tocItems.map((item) => (
								<li class:list={{ 'is-sub': item.depth === 3 }}>
									<a href={`#${item.slug}`} data-toc-link>{item.text}</a>
								</li>
							))}
						</ul>
					</nav>
				</aside>
			)}

			<div class="work-content">
				<div class="work-prose">
					<slot />
				</div>
				{externalCaseStudyUrl && (
					<section class="work-full-case-study surface-card surface-card--feature" aria-label="Full case study link" data-reveal="soft">
						<p class="work-full-case-study__eyebrow">Want the full implementation detail?</p>
						<p class="work-full-case-study__copy">
							Read the complete case study with deeper architecture decisions, section-by-section
							breakdown, and implementation reasoning.
						</p>
						<a
							href={externalCaseStudyUrl}
							target={isExternalCaseStudyLink ? "_blank" : undefined}
							rel={isExternalCaseStudyLink ? "noreferrer noopener" : undefined}
						>
							Read Full Case Study
						</a>
					</section>
				)}
				<nav class="work-nav" aria-label="Case study navigation" data-reveal="soft">
					{previous ? <a href={`/work/${previous.slug}/`}>&larr; {previous.title}</a> : <span />}
					{next ? <a href={`/work/${next.slug}/`}>{next.title} &rarr;</a> : <span />}
				</nav>
			</div>
		</div>
	</article>

	<dialog id="diagram-lightbox" class="diagram-lightbox" aria-label="Expanded diagram view">
		<div class="diagram-lightbox__panel" role="document">
			<div class="diagram-lightbox__toolbar">
				<div class="diagram-lightbox__hint">Scroll to zoom, drag to move</div>
				<div class="diagram-lightbox__controls">
					<button type="button" data-zoom-out aria-label="Zoom out">-</button>
					<button type="button" data-zoom-reset aria-label="Reset zoom">Reset</button>
					<button type="button" data-zoom-in aria-label="Zoom in">+</button>
					<button type="button" data-close aria-label="Close viewer">Close</button>
				</div>
			</div>
			<div class="diagram-lightbox__viewport" data-viewport>
				<img data-image alt="Expanded diagram" draggable="false" />
			</div>
		</div>
	</dialog>
</MainLayout>

<script is:inline>
	(() => {
		const prose = document.querySelector('.work-prose');
		const dialog = document.getElementById('diagram-lightbox');
		if (!prose || !(dialog instanceof HTMLDialogElement)) return;

		const img = dialog.querySelector('[data-image]');
		const viewport = dialog.querySelector('[data-viewport]');
		const closeBtn = dialog.querySelector('[data-close]');
		const zoomInBtn = dialog.querySelector('[data-zoom-in]');
		const zoomOutBtn = dialog.querySelector('[data-zoom-out]');
		const zoomResetBtn = dialog.querySelector('[data-zoom-reset]');

		if (!(img instanceof HTMLImageElement) || !(viewport instanceof HTMLElement)) return;

		let scale = 1;
		let tx = 0;
		let ty = 0;
		let dragging = false;
		let lastX = 0;
		let lastY = 0;

		const MIN_SCALE = 1;
		const MAX_SCALE = 6;

		const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

		const applyTransform = () => {
			img.style.transform = `translate3d(${tx}px, ${ty}px, 0) scale(${scale})`;
		};

		const resetTransform = () => {
			scale = 1;
			tx = 0;
			ty = 0;
			applyTransform();
		};

		const setScale = (nextScale) => {
			const clamped = clamp(nextScale, MIN_SCALE, MAX_SCALE);
			if (clamped === MIN_SCALE) {
				tx = 0;
				ty = 0;
			}
			scale = clamped;
			applyTransform();
		};

		const openLightbox = (sourceImg) => {
			img.src = sourceImg.currentSrc || sourceImg.src;
			img.alt = sourceImg.alt || 'Expanded diagram';
			resetTransform();
			dialog.showModal();
		};

		const closeLightbox = () => {
			if (dialog.open) dialog.close();
		};

		prose.querySelectorAll('img').forEach((sourceImg) => {
			sourceImg.classList.add('zoomable-diagram');
			sourceImg.setAttribute('tabindex', '0');
			sourceImg.setAttribute('role', 'button');
			sourceImg.setAttribute('aria-label', 'Open expanded diagram');
			sourceImg.addEventListener('click', () => openLightbox(sourceImg));
			sourceImg.addEventListener('keydown', (event) => {
				if (event.key === 'Enter' || event.key === ' ') {
					event.preventDefault();
					openLightbox(sourceImg);
				}
			});
		});

		viewport.addEventListener('wheel', (event) => {
			event.preventDefault();
			const delta = event.deltaY < 0 ? 0.18 : -0.18;
			setScale(scale + delta);
		}, { passive: false });

		viewport.addEventListener('pointerdown', (event) => {
			if (scale <= 1) return;
			dragging = true;
			lastX = event.clientX;
			lastY = event.clientY;
			viewport.setPointerCapture(event.pointerId);
			viewport.classList.add('is-dragging');
		});

		viewport.addEventListener('pointermove', (event) => {
			if (!dragging) return;
			const dx = event.clientX - lastX;
			const dy = event.clientY - lastY;
			lastX = event.clientX;
			lastY = event.clientY;
			tx += dx;
			ty += dy;
			applyTransform();
		});

		const stopDrag = (event) => {
			if (!dragging) return;
			dragging = false;
			viewport.classList.remove('is-dragging');
			if (event && viewport.hasPointerCapture(event.pointerId)) {
				viewport.releasePointerCapture(event.pointerId);
			}
		};

		viewport.addEventListener('pointerup', stopDrag);
		viewport.addEventListener('pointercancel', stopDrag);
		viewport.addEventListener('pointerleave', stopDrag);

		zoomInBtn?.addEventListener('click', () => setScale(scale + 0.3));
		zoomOutBtn?.addEventListener('click', () => setScale(scale - 0.3));
		zoomResetBtn?.addEventListener('click', resetTransform);
		closeBtn?.addEventListener('click', closeLightbox);

		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) closeLightbox();
		});

		dialog.addEventListener('close', () => {
			img.src = '';
			resetTransform();
		});
	})();
</script>

<script is:inline>
	(() => {
		const links = Array.from(document.querySelectorAll('.work-toc a[data-toc-link]'));
		if (links.length === 0) return;

		const targets = links
			.map((link) => {
				const hash = link.getAttribute('href')?.replace('#', '');
				if (!hash) return null;
				const section = document.getElementById(hash);
				return section ? { link, section } : null;
			})
			.filter(Boolean);

		if (targets.length === 0) return;

		const activate = (id) => {
			targets.forEach(({ link }) => link.removeAttribute('aria-current'));
			const active = targets.find(({ section }) => section.id === id);
			if (active) active.link.setAttribute('aria-current', 'true');
		};

		const observer = new IntersectionObserver(
			(entries) => {
				const visible = entries
					.filter((entry) => entry.isIntersecting)
					.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
				if (visible[0]) activate(visible[0].target.id);
			},
			{ rootMargin: '-20% 0px -70% 0px', threshold: [0, 1] },
		);

		targets.forEach(({ section }) => observer.observe(section));
		activate(targets[0].section.id);
	})();
</script>

<style>
	.work-article {
		max-width: min(58rem, 100%);
		margin-inline: auto;
		display: grid;
		gap: var(--space-5);
	}

	.back-link {
		font-size: var(--font-size-ui);
		font-weight: 600;
		text-decoration: none;
	}

	.work-header {
		position: relative;
		overflow: hidden;
		display: grid;
		gap: var(--space-3);
		padding: clamp(1.15rem, 1.7vw, 1.7rem);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: color-mix(in srgb, var(--color-bg-elevated) 92%, transparent);
		box-shadow: var(--shadow-sm);
	}

	.work-header::before {
		content: '';
		position: absolute;
		top: -3rem;
		right: 8%;
		width: 12rem;
		height: 12rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--color-accent) 14%, transparent);
		filter: blur(26px);
		opacity: 0.6;
		pointer-events: none;
	}

	.work-label {
		margin: 0;
		font-size: var(--font-size-xs);
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.work-header h1 {
		margin: 0;
		font-size: clamp(2rem, 1.4rem + 2.1vw, 3.1rem);
		line-height: 1.05;
	}

	.work-description {
		margin: 0;
		font-size: var(--font-size-body-lg);
		max-width: 70ch;
	}

	.work-meta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3) 1.4rem;
		font-size: var(--font-size-ui);
		color: var(--color-text-muted);
	}

	.work-meta a {
		font-weight: 700;
		text-decoration: none;
	}

	.work-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.work-body {
		display: grid;
		grid-template-columns: minmax(13rem, 15.5rem) minmax(0, 1fr);
		gap: clamp(var(--space-3), 1.8vw, var(--space-5));
		align-items: start;
	}

	.work-content {
		display: grid;
		gap: var(--space-4);
		min-width: 0;
	}

	.work-feature-media {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(15rem, 18rem);
		gap: var(--space-3);
		align-items: stretch;
		padding: 0.85rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 18%, var(--color-border));
		border-radius: var(--radius-lg);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--color-bg-elevated) 95%, transparent), color-mix(in srgb, var(--color-bg-elevated) 90%, transparent)),
			radial-gradient(circle at top right, color-mix(in srgb, var(--color-accent) 10%, transparent), transparent 38%);
		box-shadow: var(--shadow-sm);
	}

	.work-feature-media__frame {
		padding: 0.35rem;
		border: 1px solid var(--color-border);
		border-radius: calc(var(--radius-lg) - 0.2rem);
		background: color-mix(in srgb, var(--color-bg-elevated) 90%, transparent);
	}

	.work-feature-media__frame img {
		width: 100%;
		max-height: 26rem;
		object-fit: contain;
		border-radius: calc(var(--radius-lg) - 0.45rem);
	}

	.work-feature-media__meta {
		display: grid;
		align-content: start;
		gap: var(--space-1);
		padding: 0.75rem;
	}

	.work-feature-media__eyebrow {
		margin: 0;
		font-size: var(--font-size-xs);
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.work-feature-media__copy {
		margin: 0;
		font-size: var(--font-size-ui);
		line-height: 1.55;
	}

	.work-toc {
		position: sticky;
		top: 4.8rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-bg-elevated) 90%, transparent);
		padding: 0.75rem;
		max-height: calc(100vh - 7rem);
		overflow: auto;
		box-shadow: var(--shadow-sm);
	}

	.work-toc__label {
		margin: 0 0 var(--space-2);
		font-size: var(--font-size-xs);
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.work-toc ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.2rem;
	}

	.work-toc li.is-sub {
		padding-left: 0.6rem;
	}

	.work-toc a {
		display: block;
		padding: 0.28rem 0.45rem;
		border-radius: 0.45rem;
		text-decoration: none;
		font-size: var(--font-size-sm);
		color: var(--color-text-muted);
		transition: background-color 130ms ease, color 130ms ease;
	}

	.work-toc a:hover {
		color: var(--color-text);
		background: color-mix(in srgb, var(--color-accent) 11%, transparent);
	}

	.work-toc a[aria-current='true'] {
		color: var(--color-text);
		font-weight: 700;
		background: color-mix(in srgb, var(--color-accent) 17%, transparent);
	}

	.work-prose {
		display: grid;
		gap: var(--space-3);
		min-width: 0;
		padding: 0.1rem;
	}

	.work-prose :global(img.zoomable-diagram) {
		cursor: zoom-in;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-bg-elevated) 90%, transparent);
		padding: 0.35rem;
	}

	.work-prose :global(figure.diagram) {
		margin: var(--space-4) 0 var(--space-5);
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}

	.work-prose :global(figure.diagram img.zoomable-diagram) {
		width: max(100%, 980px);
		max-width: none;
	}

	.work-prose :global(figure.diagram figcaption) {
		margin-top: var(--space-2);
		font-size: var(--font-size-ui);
		color: var(--color-text-muted);
		font-style: italic;
	}

	.work-prose h2 {
		margin-top: var(--space-4);
		padding-top: var(--space-3);
		border-top: 1px solid var(--color-border);
		font-size: clamp(1.35rem, 1.1rem + 0.65vw, 1.8rem);
	}

	.work-prose p,
	.work-prose li {
		font-size: 1rem;
		line-height: 1.8;
	}

	.work-prose h3 {
		margin-top: var(--space-3);
		margin-bottom: var(--space-2);
		font-size: clamp(1.05rem, 0.98rem + 0.35vw, 1.26rem);
	}

	.work-prose > :global(p),
	.work-prose > :global(ul),
	.work-prose > :global(ol),
	.work-prose > :global(blockquote) {
		max-width: 72ch;
	}

	.work-prose :global(ul) {
		margin: 0.25rem 0 1rem;
		padding-left: 1.2rem;
		list-style: disc;
	}

	.work-prose :global(ol) {
		margin: 0.25rem 0 1rem;
		padding-left: 1.25rem;
	}

	.work-prose :global(li + li) {
		margin-top: 0.45rem;
	}

	.work-prose :global(li > p) {
		margin-bottom: 0.45rem;
	}

	.work-nav {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-3);
		padding-top: var(--space-4);
		border-top: 1px solid var(--color-border);
	}

	.work-full-case-study {
		display: grid;
		gap: var(--space-2);
		padding: clamp(0.9rem, 1.3vw, 1.15rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 32%, var(--color-border));
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-accent) 8%, var(--color-bg-elevated));
	}

	.work-full-case-study__eyebrow {
		margin: 0;
		font-size: var(--font-size-xs);
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.work-full-case-study__copy {
		margin: 0;
		font-size: var(--font-size-ui);
		color: var(--color-text-muted);
	}

	.work-full-case-study a {
		justify-self: start;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.5rem 0.9rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 45%, var(--color-border));
		border-radius: 999px;
		text-decoration: none;
		font-weight: 700;
		font-size: var(--font-size-ui);
		background: color-mix(in srgb, var(--color-bg-elevated) 85%, var(--color-accent) 15%);
	}

	.work-nav a {
		display: block;
		padding: 0.85rem 1rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-bg-elevated) 90%, transparent);
		font-weight: 600;
		text-decoration: none;
		transition:
			transform var(--motion-fast) var(--ease-standard),
			border-color var(--motion-fast) var(--ease-standard),
			box-shadow var(--motion-base) var(--ease-standard);
	}

	.work-nav a:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-accent) 34%, var(--color-border));
		box-shadow: var(--shadow-sm);
	}

	.work-nav a:focus-visible,
	.work-full-case-study a:focus-visible,
	.work-toc a:focus-visible {
		outline-offset: 3px;
	}

	.work-nav a:last-child {
		text-align: right;
	}

	.diagram-lightbox {
		border: none;
		padding: 0;
		background: transparent;
		max-width: min(94vw, 1600px);
		width: min(94vw, 1600px);
	}

	.diagram-lightbox::backdrop {
		background: rgba(5, 10, 20, 0.84);
		backdrop-filter: blur(2px);
	}

	.diagram-lightbox__panel {
		display: grid;
		gap: 0.6rem;
		padding: 0.75rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-bg-elevated) 94%, transparent);
		box-shadow: var(--shadow-lg);
	}

	.diagram-lightbox__toolbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
	}

	.diagram-lightbox__hint {
		font-size: 0.78rem;
		color: var(--color-text-muted);
	}

	.diagram-lightbox__controls {
		display: flex;
		gap: 0.35rem;
	}

	.diagram-lightbox__controls button {
		border: 1px solid var(--color-border);
		background: var(--color-bg-elevated);
		color: var(--color-text);
		font: inherit;
		font-size: 0.8rem;
		font-weight: 700;
		padding: 0.35rem 0.55rem;
		border-radius: 0.45rem;
		cursor: pointer;
	}

	.diagram-lightbox__controls button:hover {
		border-color: var(--color-accent);
	}

