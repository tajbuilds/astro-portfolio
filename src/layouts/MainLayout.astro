---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuickContact from '../components/QuickContact.astro';
import AnalyticsConsent from '../components/AnalyticsConsent.astro';

interface Props {
	title: string;
	description: string;
	image?: string;
	width?: 'narrow' | 'wide' | 'full';
	mainClass?: string;
}

const { title, description, image, width = 'narrow', mainClass } = Astro.props;
const pathname = Astro.url.pathname;
const showQuickContact = !pathname.startsWith('/contact');
const matomoUrl =
	(import.meta.env.PUBLIC_MATOMO_URL ?? 'https://stats.tajs.io').trim();
const matomoSiteId =
	(import.meta.env.PUBLIC_MATOMO_SITE_ID ?? '1').trim();
---

<!doctype html>
<html lang="en">
	<head>
		<script is:inline>
			(() => {
				const storageKey = 'theme';
				const allowedThemes = new Set(['system', 'light', 'dark', 'mist', 'forest', 'dusk', 'sand']);
				const storedTheme = localStorage.getItem(storageKey);
				const preferredTheme = allowedThemes.has(storedTheme || '') ? storedTheme : 'system';
				const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches
					? 'dark'
					: 'light';
				const resolvedTheme = preferredTheme === 'system' ? systemTheme : preferredTheme;
				document.documentElement.dataset.theme = resolvedTheme;
				document.documentElement.dataset.themePreference = preferredTheme;
			})();
		</script>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body>
		<a class="skip-link" href="#content">Skip to content</a>
		<Header />
		<main id="content" class:list={["site-main", `site-main--${width}`, mainClass]}>
			<slot />
		</main>
		<Footer />
		<script type="module" src="/scripts/starlight-mermaid.js"></script>
		{showQuickContact && <QuickContact />}
		<AnalyticsConsent matomoUrl={matomoUrl} matomoSiteId={matomoSiteId} />
		<button id="back-to-top" class="back-to-top" type="button" aria-label="Back to top">Top</button>

		<script is:inline>
			(() => {
				const btn = document.getElementById('back-to-top');
				if (!(btn instanceof HTMLButtonElement)) return;

				const toggle = () => {
					const shouldShow = window.scrollY > 900;
					btn.classList.toggle('is-visible', shouldShow);
					btn.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');
				};

				toggle();
				window.addEventListener('scroll', toggle, { passive: true });

				const footer = document.querySelector('footer');
				if (footer && 'IntersectionObserver' in window) {
					const observer = new IntersectionObserver((entries) => {
						const visible = entries.some((entry) => entry.isIntersecting);
						btn.classList.toggle('is-over-footer', visible);
					});
					observer.observe(footer);
				}

				btn.addEventListener('click', () => {
					window.scrollTo({ top: 0, behavior: 'smooth' });
				});
			})();
		</script>
	</body>
</html>
