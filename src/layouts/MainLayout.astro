---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuickContact from '../components/QuickContact.astro';
import AnalyticsConsent from '../components/AnalyticsConsent.astro';

interface Props {
	title: string;
	description: string;
	image?: string;
	width?: 'narrow' | 'wide' | 'full';
	mainClass?: string;
}

const { title, description, image, width = 'narrow', mainClass } = Astro.props;
const pathname = Astro.url.pathname;
const showQuickContact = !pathname.startsWith('/contact');
const runtimeEnv = Astro.locals.runtime?.env;
const matomoUrl =
	(runtimeEnv?.MATOMO_URL ?? import.meta.env.PUBLIC_MATOMO_URL ?? '').trim();
const matomoSiteId =
	(runtimeEnv?.MATOMO_SITE_ID ?? import.meta.env.PUBLIC_MATOMO_SITE_ID ?? '').trim();
---

<!doctype html>
<html lang="en">
	<head>
		<script is:inline>
			(() => {
				const storageKey = 'theme';
				const storedTheme = localStorage.getItem(storageKey);
				const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches
					? 'dark'
					: 'light';
				const theme = storedTheme === 'dark' || storedTheme === 'light' ? storedTheme : systemTheme;
				document.documentElement.dataset.theme = theme;
			})();
		</script>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body>
		<a class="skip-link" href="#content">Skip to content</a>
		<Header />
		<main id="content" class:list={["site-main", `site-main--${width}`, mainClass]}>
			<slot />
		</main>
		<Footer />
		{showQuickContact && <QuickContact />}
		<AnalyticsConsent matomoUrl={matomoUrl} matomoSiteId={matomoSiteId} />
		<button id="back-to-top" class="back-to-top" type="button" aria-label="Back to top">Top</button>

		<script is:inline>
			(() => {
				const btn = document.getElementById('back-to-top');
				if (!(btn instanceof HTMLButtonElement)) return;

				const toggle = () => {
					const shouldShow = window.scrollY > 900;
					btn.classList.toggle('is-visible', shouldShow);
					btn.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');
				};

				toggle();
				window.addEventListener('scroll', toggle, { passive: true });

				const footer = document.querySelector('footer');
				if (footer && 'IntersectionObserver' in window) {
					const observer = new IntersectionObserver((entries) => {
						const visible = entries.some((entry) => entry.isIntersecting);
						btn.classList.toggle('is-over-footer', visible);
					});
					observer.observe(footer);
				}

				btn.addEventListener('click', () => {
					window.scrollTo({ top: 0, behavior: 'smooth' });
				});
			})();
		</script>
	</body>
</html>
